---
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import Search from '../components/Search.astro';
import Icon from '../components/ui/Icon.astro';
import Toaster from '../components/ui/Toaster.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'Article' | 'Organization' | 'WebPage';
  schemaData?: any;
}

const {
  title = 'HisaabKar.pk - Pakistani Finance & Utility Hub',
  description = 'Real-time Pakistani economic data, tax calculation tools, and financial insights for the digital age.',
  image = '/og-image.png',
  type = 'WebPage',
  schemaData = {}
} = Astro.props;

const url = new URL(Astro.url.pathname, Astro.site);
const fullURL = url.href;

const schemaDataWithDefaults = {
  ...schemaData,
  url: fullURL
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#16a34a" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type === 'Article' ? 'article' : 'website'} />
    <meta property="og:url" content={fullURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site).href} />

    <!-- Canonical URL -->
    <link rel="canonical" href={fullURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <SchemaOrg type={type} data={schemaDataWithDefaults} />

    <!-- Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-T3BWZ1K93N"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-T3BWZ1K93N');
    </script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 antialiased transition-colors duration-300">
    <!-- T065: Offline banner (shown by SW when offline) -->
