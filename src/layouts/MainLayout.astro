    <!-- E-E-A-T Compliance Footer -->
    <!-- T087: Newsletter form handler -->
    <script>
      const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
      const msg = document.getElementById('newsletter-msg');
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
        const email = emailInput?.value?.trim();
        if (!email) return;
        try {
          const res = await fetch('/api/newsletter/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json() as { message?: string; error?: string };
          if (msg) {
            msg.textContent = data.message || data.error || 'Check your email to confirm subscription.';
            msg.classList.remove('hidden');
            msg.classList.toggle('text-green-600', res.ok);
            msg.classList.toggle('text-red-600', !res.ok);
          }
          if (res.ok) emailInput.value = '';
          if (typeof showToast !== 'undefined') {
            showToast({ message: res.ok ? 'Check your email to confirm!' : (data.error || 'Failed'), type: res.ok ? 'success' : 'error', duration: 3000 });
          }
        } catch (err) {
          if (msg) {
            msg.textContent = 'Failed to subscribe. Please try again.';
            msg.classList.remove('hidden');
            msg.classList.add('text-red-600');
          }
          if (typeof showToast !== 'undefined') {
            showToast({ message: 'Subscription failed', type: 'error', duration: 3000 });
          }
        }
      });
    </script>

    <!-- T064: PWA service worker registration -->
    <script>
      import { registerSW } from 'virtual:pwa-register';
      registerSW({
        onOfflineReady() {
          const banner = document.getElementById('offline-banner');
          if (banner) banner.classList.remove('hidden');
          console.log('HisaabKar.pk ready for offline use');
        },
        onNeedRefresh() {
          // Auto-update SW silently
        },
      });
    </script>


<!-- Dark Mode Toggle Script -->
    <script is:inline>
      (function() {
        // Check for saved user preference or system preference
        const savedTheme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        // Apply theme
        if (savedTheme === 'dark' || (!savedTheme && systemDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }

        // Toggle function
        window.toggleDarkMode = function() {
          const html = document.documentElement;
          const isDark = html.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');

          // Show toast notification
          if (typeof showToast !== 'undefined') {
            showToast({
              message: isDark ? 'Dark mode enabled' : 'Light mode enabled',
              type: 'info',
              duration: 2000
            });
          }
        };
      })();
    </script>

