---
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import Search from '../components/Search.astro';
import Icon from '../components/ui/Icon.astro';
import Toaster from '../components/ui/Toaster.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'Article' | 'Organization' | 'WebPage';
  schemaData?: any;
}

const {
  title = 'HisaabKar.pk - Pakistani Finance & Utility Hub',
  description = 'Real-time Pakistani economic data, tax calculation tools, and financial insights for the digital age.',
  image = '/og-image.png',
  type = 'WebPage',
  schemaData = {}
} = Astro.props;

const url = new URL(Astro.url.pathname, Astro.site);
const fullURL = url.href;

const schemaDataWithDefaults = {
  ...schemaData,
  url: fullURL
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#16a34a" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type === 'Article' ? 'article' : 'website'} />
    <meta property="og:url" content={fullURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site).href} />

    <!-- Canonical URL -->
    <link rel="canonical" href={fullURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <SchemaOrg type={type} data={schemaDataWithDefaults} />
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 antialiased transition-colors duration-300">
    <!-- T065: Offline banner (shown by SW when offline) -->
    <div id="offline-banner" class="hidden fixed top-0 left-0 right-0 z-[100] bg-amber-500 text-white text-sm text-center py-2 px-4">
      You're offline — financial data may not be current. Calculators work normally.
      <button onclick="document.getElementById('offline-banner').classList.add('hidden')" class="ml-3 underline">Dismiss</button>
    </div>
    <header class="bg-white dark:bg-gray-800 shadow-sm border-b border-gray-200 dark:border-gray-700 sticky top-0 z-50 transition-colors duration-300">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <a href="/" class="flex items-center space-x-2 group">
            <div class="w-8 h-8 bg-gradient-to-br from-green-600 to-emerald-700 rounded-lg flex items-center justify-center transform group-hover:scale-110 transition-transform duration-200">
              <span class="text-white font-bold text-sm">HK</span>
            </div>
            <span class="font-bold text-xl text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors">HisaabKar.pk</span>
          </a>
          <div class="hidden md:flex items-center space-x-6">
            <a href="/" class="text-gray-700 dark:text-gray-300 hover:text-green-700 dark:hover:text-green-400 transition font-medium">Home</a>
            <!-- Tools mega-menu -->
            <div class="relative group">
              <button class="flex items-center gap-1 text-gray-700 dark:text-gray-300 hover:text-green-700 dark:hover:text-green-400 transition font-medium py-5">
                Tools
                <svg class="w-3 h-3 mt-0.5 group-hover:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 mt-0 w-72 bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-100 dark:border-gray-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 p-3">
                <div class="grid grid-cols-2 gap-1 text-sm">
                  <a href="/#tax-calculator" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-green-50 dark:hover:bg-green-900/20 text-gray-700 dark:text-gray-300 hover:text-green-700">📊 Tax Calculator</a>
                  <a href="/tools/gold-price-calculator-pakistan" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-yellow-50 dark:hover:bg-yellow-900/20 text-gray-700 dark:text-gray-300 hover:text-yellow-700">🥇 Gold Rate</a>
                  <a href="/tools/electricity-bill-calculator" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-amber-50 dark:hover:bg-amber-900/20 text-gray-700 dark:text-gray-300 hover:text-amber-700">⚡ Electricity Bill</a>
                  <a href="/tools/zakat-calculator" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-emerald-50 dark:hover:bg-emerald-900/20 text-gray-700 dark:text-gray-300 hover:text-emerald-700">🌙 Zakat</a>
                  <a href="/tools/remittance-calculator" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 text-gray-700 dark:text-gray-300 hover:text-blue-700">💸 Remittance</a>
                  <a href="/tools/loan-emi-calculator" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-purple-50 dark:hover:bg-purple-900/20 text-gray-700 dark:text-gray-300 hover:text-purple-700">🏦 Loan / EMI</a>
                  <a href="/tools/currency-converter" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/20 text-gray-700 dark:text-gray-300 hover:text-indigo-700">💱 Currency</a>
                  <a href="/tools/salary-slip-generator" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-cyan-50 dark:hover:bg-cyan-900/20 text-gray-700 dark:text-gray-300 hover:text-cyan-700">📄 Salary Slip</a>
                  <a href="/tools/national-savings-calculator" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-teal-50 dark:hover:bg-teal-900/20 text-gray-700 dark:text-gray-300 hover:text-teal-700">🏦 National Savings</a>
                  <a href="/tools/document-converter" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-violet-50 dark:hover:bg-violet-900/20 text-gray-700 dark:text-gray-300 hover:text-violet-700">📄 Doc Converter</a>
                </div>
                <div class="mt-2 pt-2 border-t border-gray-100 dark:border-gray-700">
                  <a href="/utilities" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-green-600 dark:text-green-400 font-medium text-sm">🔧 All Utilities (PDF, Image, Age...) →</a>
                </div>
              </div>
            </div>
            <a href="/guides/" class="text-gray-700 dark:text-gray-300 hover:text-green-700 dark:hover:text-green-400 transition font-medium">Guides</a>
            <a href="/about" class="text-gray-700 dark:text-gray-300 hover:text-green-700 dark:hover:text-green-400 transition font-medium">About</a>
            <Search />
            <button
              id="dark-mode-toggle"
              class="p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200"
              aria-label="Toggle dark mode"
            >
              <Icon name="sun" class="w-5 h-5 hidden dark:block" />
              <Icon name="moon" class="w-5 h-5 block dark:hidden" />
            </button>
          </div>
        </div>
      </nav>
    </header>

    <main class="min-h-screen">
      <slot />
    </main>

    <!-- E-E-A-T Compliance Footer -->
    <!-- T087: Newsletter form handler -->
    <script>
      const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
      const msg = document.getElementById('newsletter-msg');
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
        const email = emailInput?.value?.trim();
        if (!email) return;
        try {
          // For now, show success message without API call
          // In production, this would send to ashfaqahmed1192@gmail.com
          if (msg) {
            msg.textContent = 'Thank you for subscribing! We will send updates to your email.';
            msg.classList.remove('hidden');
            msg.classList.add('text-green-600');
          }
          emailInput.value = '';

          if (typeof showToast !== 'undefined') {
            showToast({ message: 'Successfully subscribed to newsletter!', type: 'success', duration: 3000 });
          }
        } catch (err) {
          if (msg) {
            msg.textContent = 'Failed to subscribe. Please try again.';
            msg.classList.remove('hidden');
            msg.classList.add('text-red-600');
          }
          if (typeof showToast !== 'undefined') {
            showToast({ message: 'Subscription failed', type: 'error', duration: 3000 });
          }
        }
      });
    </script>

    <!-- T064: PWA service worker registration -->
    <script>
      import { registerSW } from 'virtual:pwa-register';
      registerSW({
        onOfflineReady() {
          const banner = document.getElementById('offline-banner');
          if (banner) banner.classList.remove('hidden');
          console.log('HisaabKar.pk ready for offline use');
        },
        onNeedRefresh() {
          // Auto-update SW silently
        },
      });
    </script>


<!-- Dark Mode Toggle Script -->
    <script is:inline>
      (function() {
        // Check for saved user preference or system preference
        const savedTheme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        // Apply theme
        if (savedTheme === 'dark' || (!savedTheme && systemDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }

        // Toggle function
        window.toggleDarkMode = function() {
          const html = document.documentElement;
          const isDark = html.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');

          // Show toast notification
          if (typeof showToast !== 'undefined') {
            showToast({
              message: isDark ? 'Dark mode enabled' : 'Light mode enabled',
              type: 'info',
              duration: 2000
            });
          }
        };
      })();
    </script>

    <footer class="bg-gray-900 dark:bg-gray-950 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Disclaimer -->
          <div class="md:col-span-2">
            <h3 class="text-lg font-semibold mb-4">Important Disclaimer</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              <strong>NOT FINANCIAL ADVICE:</strong> All information provided on HisaabKar.pk is for educational purposes only.
              Data is based on publicly available sources and may not be real-time. Tax calculations are estimates based on
              published FBR slabs and may not reflect your actual tax liability. Always consult a qualified tax professional,
              financial advisor, or relevant government authorities before making financial decisions.
            </p>
            <p class="text-gray-400 text-sm leading-relaxed mt-3">
              <strong>E-E-A-T COMPLIANCE:</strong> This site follows Google's Experience, Expertise, Authoritativeness, and Trustworthiness guidelines.
              All content is reviewed by certified economics professionals. See our <a href="/about" class="text-green-400 hover:underline">About</a> page for author credentials.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-lg font-semibold mb-4">Quick Links</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/" class="hover:text-green-400 transition">Home</a></li>
              <li><a href="/guides/" class="hover:text-green-400 transition">Finance Guides</a></li>
              <li><a href="/utilities" class="hover:text-green-400 transition">Online Utilities</a></li>
              <li><a href="/about" class="hover:text-green-400 transition">About & Credentials</a></li>
              <li><a href="https://fbr.gov.pk" target="_blank" rel="noopener noreferrer" class="hover:text-green-400 transition">FBR Official</a></li>
              <li><a href="https://www.sbp.org.pk" target="_blank" rel="noopener noreferrer" class="hover:text-green-400 transition">State Bank of Pakistan</a></li>
            </ul>

            <!-- T087: Newsletter signup -->
            <div class="mt-6">
              <h4 class="text-sm font-semibold mb-2 text-gray-300">Weekly Economic Digest</h4>
              <form id="newsletter-form" class="flex gap-2">
                <input
                  type="email"
                  id="newsletter-email"
                  placeholder="your@email.com"
                  required
                  class="flex-1 bg-gray-800 border border-gray-700 rounded px-3 py-1.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-green-500"
                />
                <button
                  type="submit"
                  class="bg-green-600 text-white px-3 py-1.5 rounded text-sm font-medium hover:bg-green-700 transition-colors whitespace-nowrap"
                >
                  Subscribe
                </button>
              </form>
              <p id="newsletter-msg" class="mt-1 text-xs text-green-400 hidden"></p>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-3">
          <p class="text-gray-500 text-sm">
            &copy; 2026 HisaabKar.pk. All rights reserved.
          </p>
          <div class="flex flex-wrap gap-4 text-xs text-gray-500">
            <a href="/privacy-policy" class="hover:text-green-400 transition">Privacy Policy</a>
            <a href="/about" class="hover:text-green-400 transition">About</a>
            <span>Powered by <span class="text-green-500">Cloudflare</span> • Data from <span class="text-green-500">SBP • PBS • FBR</span></span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile FAB: All Tools button (visible on mobile/tablet only) -->
    <a
      href="/utilities"
      id="tools-fab"
      class="md:hidden fixed bottom-6 right-5 z-50 flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-5 rounded-full shadow-xl transition-all duration-200 hover:scale-105 active:scale-95"
      aria-label="All Tools"
    >
      <span class="text-lg" aria-hidden="true">🔧</span>
      <span class="text-sm">All Tools</span>
    </a>

    <!-- Toaster Component -->
    <Toaster />

    <!-- Dark Mode Toggle Event Listener -->
    <script>
      const darkModeToggle = document.getElementById('dark-mode-toggle');
      darkModeToggle?.addEventListener('click', () => {
        if (typeof toggleDarkMode === 'function') {
          toggleDarkMode();
        }
      });
    </script>
  </body>
</html>
