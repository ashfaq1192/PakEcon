---
// T071: Pagefind search modal component
// Pagefind indexes prerendered pages at build time (npm run build includes pagefind CLI)
---

<!-- Search icon button -->
<button
  id="search-open"
  aria-label="Search PakEcon.ai"
  class="p-2 text-gray-600 hover:text-green-700 transition-colors"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>
</button>

<!-- Search modal overlay -->
<div id="search-modal" class="hidden fixed inset-0 z-[200] flex items-start justify-center pt-20 px-4">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/50"></div>

  <!-- Modal panel -->
  <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-lg">
    <div class="p-4 border-b border-gray-200">
      <input
        id="search-input"
        type="text"
        placeholder="Search PakEcon.ai..."
        class="w-full text-base outline-none text-gray-900 placeholder-gray-400"
        autocomplete="off"
        autofocus
      />
    </div>
    <div id="search-results" class="max-h-80 overflow-y-auto p-2">
      <p id="search-placeholder" class="text-sm text-gray-400 p-3">Type to search tools and insights…</p>
    </div>
  </div>
</div>

<script>
  const openBtn = document.getElementById('search-open');
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('search-results')!;
  const placeholder = document.getElementById('search-placeholder')!;

  let pagefindLoaded = false;
  let pagefind: any = null;
  let debounceTimer: ReturnType<typeof setTimeout>;

  function openModal() {
    modal?.classList.remove('hidden');
    input?.focus();
  }

  function closeModal() {
    modal?.classList.add('hidden');
    if (input) input.value = '';
    resultsEl.innerHTML = '';
    resultsEl.appendChild(placeholder);
    placeholder.classList.remove('hidden');
  }

  openBtn?.addEventListener('click', openModal);
  backdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeModal();
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    }
  });

  async function loadPagefind() {
    if (pagefindLoaded) return;
    try {
      // @ts-ignore — pagefind is generated at build time
      pagefind = await import('/pagefind/pagefind.js');
      pagefindLoaded = true;
    } catch {
      // Pagefind not available in dev mode (only after build)
    }
  }

  input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
      const query = input.value.trim();
      if (!query) {
        resultsEl.innerHTML = '';
        resultsEl.appendChild(placeholder);
        placeholder.classList.remove('hidden');
        return;
      }

      await loadPagefind();

      if (!pagefind) {
        resultsEl.innerHTML = '<p class="text-sm text-gray-400 p-3">Search unavailable — please run a production build first.</p>';
        return;
      }

      placeholder.classList.add('hidden');
      const search = await pagefind.search(query);
      const results = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));

      if (results.length === 0) {
        resultsEl.innerHTML = '<p class="text-sm text-gray-400 p-3">No results found.</p>';
        return;
      }

      resultsEl.innerHTML = results
        .map(
          (r: any) => `
          <a href="${r.url}" class="block p-3 rounded-lg hover:bg-gray-50 transition-colors">
            <div class="text-sm font-medium text-gray-900">${r.meta?.title || 'Untitled'}</div>
            <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">${r.excerpt || ''}</div>
            <div class="text-xs text-green-600 mt-1">${r.url}</div>
          </a>`
        )
        .join('');
    }, 200);
  });
</script>
