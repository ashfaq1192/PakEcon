---
// QuickTools bar — "Utility Hero" layout per Pakistani UX best practices
// Shows top tools immediately above the fold for instant discovery
---
<section class="py-5 bg-white dark:bg-gray-800 border-b border-gray-100 dark:border-gray-700 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-4">
      Free Tools — Seedha Yahan Se Shuru Karein
    </p>
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
      <a href="/#tax-calculator"
        class="group flex flex-col items-center gap-2 p-4 rounded-xl bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 hover:bg-green-100 dark:hover:bg-green-900/40 hover:scale-105 transition-all duration-200 text-center border border-green-100 dark:border-green-800">
        <span class="text-2xl" aria-hidden="true">📊</span>
        <span class="text-xs font-semibold leading-tight">Tax Calculate<br/>Karein</span>
      </a>
      <a href="/tools/gold-price-calculator-pakistan"
        class="group flex flex-col items-center gap-2 p-4 rounded-xl bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-400 hover:bg-yellow-100 dark:hover:bg-yellow-900/40 hover:scale-105 transition-all duration-200 text-center border border-yellow-100 dark:border-yellow-800">
        <span class="text-2xl" aria-hidden="true">🥇</span>
        <span class="text-xs font-semibold leading-tight">Gold Rate<br/>Check Karein</span>
      </a>
      <a href="/tools/electricity-bill-calculator"
        class="group flex flex-col items-center gap-2 p-4 rounded-xl bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/40 hover:scale-105 transition-all duration-200 text-center border border-amber-100 dark:border-amber-800">
        <span class="text-2xl" aria-hidden="true">⚡</span>
        <span class="text-xs font-semibold leading-tight">Bijli Bill<br/>Calculate Karein</span>
      </a>
      <a href="/tools/remittance-calculator"
        class="group flex flex-col items-center gap-2 p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/40 hover:scale-105 transition-all duration-200 text-center border border-blue-100 dark:border-blue-800">
        <span class="text-2xl" aria-hidden="true">💸</span>
        <span class="text-xs font-semibold leading-tight">Remittance<br/>Check Karein</span>
      </a>
      <a href="/tools/document-converter"
        class="group flex flex-col items-center gap-2 p-4 rounded-xl bg-purple-50 dark:bg-purple-900/20 text-purple-700 dark:text-purple-400 hover:bg-purple-100 dark:hover:bg-purple-900/40 hover:scale-105 transition-all duration-200 text-center border border-purple-100 dark:border-purple-800">
        <span class="text-2xl" aria-hidden="true">📄</span>
        <span class="text-xs font-semibold leading-tight">Word / Excel<br/>→ PDF</span>
      </a>
      <a href="/tools/zakat-calculator"
        class="group flex flex-col items-center gap-2 p-4 rounded-xl bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-400 hover:bg-emerald-100 dark:hover:bg-emerald-900/40 hover:scale-105 transition-all duration-200 text-center border border-emerald-100 dark:border-emerald-800">
        <span class="text-2xl" aria-hidden="true">🌙</span>
        <span class="text-xs font-semibold leading-tight">Zakat<br/>Calculate Karein</span>
      </a>
    </div>
  </div>
</section>
