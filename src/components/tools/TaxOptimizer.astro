---
import TaxCalculator from './TaxCalculator';
---

<div class="max-w-4xl mx-auto p-6">
  <div class="mb-6">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">2026 Pakistan Tax Optimizer</h2>
    <p class="text-gray-600">
      Calculate your income tax based on FBR 2026 tax slabs. Includes Digital Nation Act credits for freelancers and IT professionals.
    </p>
  </div>
  <TaxCalculator client:load />
</div>
