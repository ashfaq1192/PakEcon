---
---
<div class="max-w-2xl mx-auto p-6">
  <div class="mb-4">
    <h3 class="text-2xl font-bold text-gray-900 mb-2">PDF to Images Converter</h3>
    <p class="text-gray-600 text-sm">Convert PDF pages to images directly in your browser - 100% client-side</p>
  </div>

  <div id="pdf-converter" class="bg-white rounded-lg shadow-lg p-6">
    <div class="space-y-4">
      <!-- File Input -->
      <div>
        <label for="pdf-input" class="block text-sm font-medium text-gray-700 mb-1">
          Select PDF File
        </label>
        <input
          type="file"
          id="pdf-input"
          accept=".pdf"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-green-50 file:text-green-700 hover:file:bg-green-100"
        />
      </div>

      <!-- Options -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="image-format" class="block text-sm font-medium text-gray-700 mb-1">
            Output Format
          </label>
          <select
            id="image-format"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
          >
            <option value="image/png">PNG</option>
            <option value="image/jpeg">JPEG</option>
            <option value="image/webp">WebP</option>
          </select>
        </div>

        <div>
          <label for="image-scale" class="block text-sm font-medium text-gray-700 mb-1">
            Quality Scale
          </label>
          <select
            id="image-scale"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
          >
            <option value="1">1x (Original)</option>
            <option value="1.5">1.5x</option>
            <option value="2" selected>2x (Recommended)</option>
            <option value="3">3x</option>
          </select>
        </div>
      </div>

      <button
        id="convert-btn"
        disabled
        class="w-full bg-green-600 hover:bg-green-700 disabled:bg-gray-400 disabled:cursor-not-allowed text-white font-medium py-2 px-4 rounded-lg transition"
      >
        Convert to Images
      </button>

      <!-- Progress -->
      <div id="progress-container" class="hidden">
        <div class="bg-gray-200 rounded-full h-2">
          <div id="progress-bar" class="bg-green-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
        <p id="progress-text" class="text-sm text-gray-600 mt-2 text-center">Processing...</p>
      </div>

      <!-- Results -->
      <div id="results-container" class="hidden space-y-4">
        <button
          id="download-all-btn"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition"
        >
          Download All Images
        </button>

        <div id="images-preview" class="grid grid-cols-2 gap-4"></div>
      </div>

      <!-- PDF.js Library -->
      <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" integrity="sha512-HHm2hG6+3bQkKdK4jv2fz5Mf5d9jB0v8jJF8/5h9k8yW7Uo8iJ8hN1i5Yv5d9N4Z0N5d9N4Z0N5d9N4Z0N5d9N4Z0N5d" crossorigin="anonymous"></script>
    </div>
  </div>

  <script>
    // Initialize PDF.js worker
    if (window.pdfjsLib) {
      window.pdfjsLib.GlobalWorkerOptions.workerSrc =
        'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    }

    const pdfInput = document.getElementById('pdf-input');
    const convertBtn = document.getElementById('convert-btn');
    const progressContainer = document.getElementById('progress-container');
    const progressBar = document.getElementById('progress-bar');
    const progressText = document.getElementById('progress-text');
    const resultsContainer = document.getElementById('results-container');
    const imagesPreview = document.getElementById('images-preview');
    const downloadAllBtn = document.getElementById('download-all-btn');

    let convertedImages: Blob[] = [];

    pdfInput.addEventListener('change', (e) => {
      convertBtn.disabled = !e.target.files || !e.target.files[0];
      resultsContainer.classList.add('hidden');
      imagesPreview.innerHTML = '';
      convertedImages = [];
    });

    convertBtn.addEventListener('click', async () => {
      const file = pdfInput.files?.[0];
      if (!file) return;

      const imageFormat = document.getElementById('image-format').value;
      const scale = parseFloat(document.getElementById('image-scale').value);

      convertBtn.disabled = true;
      progressContainer.classList.remove('hidden');
      resultsContainer.classList.add('hidden');
      imagesPreview.innerHTML = '';
      convertedImages = [];

      try {
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await window.pdfjsLib.getDocument({ data: arrayBuffer }).promise;

        const totalPages = pdf.numPages;
        progressBar.style.width = '0%';
        progressText.textContent = `Processing page 0 of ${totalPages}...`;

        for (let i = 1; i <= totalPages; i++) {
          const page = await pdf.getPage(i);
          const viewport = page.getViewport({ scale });

          const canvas = document.createElement('canvas');
          const context = canvas.getContext('2d');
          canvas.width = viewport.width;
          canvas.height = viewport.height;

          await page.render({
            canvasContext: context,
            viewport
          }).promise;

          const blob = await new Promise<Blob>((resolve) => {
            canvas.toBlob(resolve, imageFormat, 0.92);
          });

          convertedImages.push(blob);

          // Add preview
          const img = document.createElement('img');
          img.src = URL.createObjectURL(blob);
          img.className = 'w-full rounded-lg border border-gray-200';
          img.alt = `Page ${i}`;

          const div = document.createElement('div');
          div.className = 'space-y-1';
          div.innerHTML = `
            <p class="text-sm font-medium text-gray-700">Page ${i}</p>
            <a href="${img.src}" download="${file.name.replace('.pdf', '')}_page_${i}.${imageFormat.split('/')[1]}" class="text-sm text-green-600 hover:underline">Download</a>
          `;
          div.appendChild(img);
          imagesPreview.appendChild(div);

          // Update progress
          const progress = (i / totalPages) * 100;
          progressBar.style.width = `${progress}%`;
          progressText.textContent = `Processing page ${i} of ${totalPages}...`;
        }

        progressContainer.classList.add('hidden');
        resultsContainer.classList.remove('hidden');
        progressText.textContent = `Successfully converted ${totalPages} page${totalPages !== 1 ? 's' : ''}!`;

      } catch (error) {
        progressText.textContent = `Error: ${error.message}`;
        progressBar.classList.add('bg-red-600');
        progressBar.classList.remove('bg-green-600');
      }

      convertBtn.disabled = false;
    });

    downloadAllBtn.addEventListener('click', () => {
      convertedImages.forEach((blob, index) => {
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `converted_page_${index + 1}.${blob.type.split('/')[1]}`;
        link.click();
      });
    });
  </script>
</div>
