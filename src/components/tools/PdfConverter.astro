---
---
<div class="max-w-2xl mx-auto p-6">
  <div class="mb-4">
    <h3 class="text-2xl font-bold text-gray-900 mb-2">PDF to Images Converter</h3>
    <p class="text-gray-600 text-sm">Convert PDF pages to images directly in your browser - 100% client-side</p>
  </div>

  <div id="pdf-converter" class="bg-white rounded-lg shadow-lg p-6">
    <div class="space-y-4">
      <!-- File Input -->
      <div>
        <label for="pdf-input" class="block text-sm font-medium text-gray-700 mb-1">
          Select PDF File
        </label>
        <input
          type="file"
          id="pdf-input"
          accept=".pdf"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-green-50 file:text-green-700 hover:file:bg-green-100"
        />
      </div>

      <!-- Options -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="image-format" class="block text-sm font-medium text-gray-700 mb-1">
            Output Format
          </label>
          <select
            id="image-format"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
          >
            <option value="image/png">PNG</option>
            <option value="image/jpeg">JPEG</option>
            <option value="image/webp">WebP</option>
          </select>
        </div>

        <div>
          <label for="image-scale" class="block text-sm font-medium text-gray-700 mb-1">
            Quality Scale
          </label>
          <select
            id="image-scale"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
          >
            <option value="1">1x (Original)</option>
            <option value="1.5">1.5x</option>
            <option value="2" selected>2x (Recommended)</option>
            <option value="3">3x</option>
          </select>
        </div>
      </div>

      <button
        id="convert-btn"
        disabled
        class="w-full bg-green-600 hover:bg-green-700 disabled:bg-gray-400 disabled:cursor-not-allowed text-white font-medium py-2 px-4 rounded-lg transition"
      >
        Convert to Images
      </button>

      <!-- Progress -->
      <div id="progress-container" class="hidden">
        <div class="bg-gray-200 rounded-full h-2">
          <div id="progress-bar" class="bg-green-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
        <p id="progress-text" class="text-sm text-gray-600 mt-2 text-center">Processing...</p>
      </div>

      <!-- Results -->
      <div id="results-container" class="hidden space-y-4">
        <button
          id="download-all-btn"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition"
        >
          Download All Images
        </button>

        <div id="images-preview" class="grid grid-cols-2 gap-4"></div>
      </div>

    </div>
  </div>

  <script is:inline>
    const PDFJS_CDN = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
    const PDFJS_WORKER = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    // Dynamically load PDF.js and resolve once ready
    function loadPdfJs() {
      return new Promise(function(resolve, reject) {
        if (window.pdfjsLib) { resolve(window.pdfjsLib); return; }
        var s = document.createElement('script');
        s.src = PDFJS_CDN;
        s.onload = function() {
          window.pdfjsLib.GlobalWorkerOptions.workerSrc = PDFJS_WORKER;
          resolve(window.pdfjsLib);
        };
        s.onerror = function() { reject(new Error('Failed to load PDF.js')); };
        document.head.appendChild(s);
      });
    }

    var pdfInput        = document.getElementById('pdf-input');
    var convertBtn      = document.getElementById('convert-btn');
    var progressContainer = document.getElementById('progress-container');
    var progressBar     = document.getElementById('progress-bar');
    var progressText    = document.getElementById('progress-text');
    var resultsContainer = document.getElementById('results-container');
    var imagesPreview   = document.getElementById('images-preview');
    var downloadAllBtn  = document.getElementById('download-all-btn');
    var convertedImages = [];

    pdfInput.addEventListener('change', function(e) {
      convertBtn.disabled = !(e.target.files && e.target.files[0]);
      resultsContainer.classList.add('hidden');
      imagesPreview.innerHTML = '';
      convertedImages = [];
    });

    convertBtn.addEventListener('click', async function() {
      var file = pdfInput.files && pdfInput.files[0];
      if (!file) return;

      var imageFormat = document.getElementById('image-format').value;
      var scale = parseFloat(document.getElementById('image-scale').value);

      convertBtn.disabled = true;
      progressContainer.classList.remove('hidden');
      resultsContainer.classList.add('hidden');
      imagesPreview.innerHTML = '';
      convertedImages = [];
      progressBar.classList.remove('bg-red-600');
      progressBar.classList.add('bg-green-600');

      try {
        var pdfjsLib = await loadPdfJs();
        var arrayBuffer = await file.arrayBuffer();
        var pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
        var totalPages = pdf.numPages;

        progressBar.style.width = '0%';
        progressText.textContent = 'Processing page 0 of ' + totalPages + '...';

        for (var i = 1; i <= totalPages; i++) {
          var page = await pdf.getPage(i);
          var viewport = page.getViewport({ scale: scale });

          var canvas = document.createElement('canvas');
          var context = canvas.getContext('2d');
          canvas.width = viewport.width;
          canvas.height = viewport.height;

          await page.render({ canvasContext: context, viewport: viewport }).promise;

          var blob = await new Promise(function(resolve) {
            canvas.toBlob(resolve, imageFormat, 0.92);
          });

          convertedImages.push(blob);

          var objectUrl = URL.createObjectURL(blob);
          var ext = imageFormat.split('/')[1];
          var baseName = file.name.replace(/\.pdf$/i, '');

          var img = document.createElement('img');
          img.src = objectUrl;
          img.className = 'w-full rounded-lg border border-gray-200 mt-1';
          img.alt = 'Page ' + i;

          var div = document.createElement('div');
          div.className = 'space-y-1';
          div.innerHTML =
            '<p class="text-sm font-medium text-gray-700">Page ' + i + '</p>' +
            '<a href="' + objectUrl + '" download="' + baseName + '_page_' + i + '.' + ext + '" class="text-sm text-green-600 hover:underline">Download</a>';
          div.appendChild(img);
          imagesPreview.appendChild(div);

          var progress = (i / totalPages) * 100;
          progressBar.style.width = progress + '%';
          progressText.textContent = 'Processing page ' + i + ' of ' + totalPages + '...';
        }

        progressContainer.classList.add('hidden');
        resultsContainer.classList.remove('hidden');

      } catch (err) {
        progressContainer.classList.remove('hidden');
        progressText.textContent = 'Error: ' + (err.message || 'Conversion failed');
        progressBar.classList.remove('bg-green-600');
        progressBar.classList.add('bg-red-600');
      }

      convertBtn.disabled = false;
    });

    downloadAllBtn.addEventListener('click', function() {
      var imageFormat = document.getElementById('image-format').value;
      var ext = imageFormat.split('/')[1];
      convertedImages.forEach(function(blob, index) {
        var link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'converted_page_' + (index + 1) + '.' + ext;
        link.click();
      });
    });
  </script>
</div>
