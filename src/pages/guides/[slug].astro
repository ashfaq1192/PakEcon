---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pubDateDisplay = entry.data.pubDate.toLocaleDateString('en-PK', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const categoryColors: Record<string, string> = {
  taxation: 'bg-green-50 text-green-700',
  policy: 'bg-blue-50 text-blue-700',
  investment: 'bg-purple-50 text-purple-700',
  inflation: 'bg-orange-50 text-orange-700',
  remittance: 'bg-red-50 text-red-700',
  banking: 'bg-teal-50 text-teal-700',
};
const catColor = categoryColors[entry.data.category] ?? 'bg-gray-100 text-gray-600';

const pageUrl = `https://hisaabkar.pk/guides/${entry.id}`;
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hisaabkar.pk/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://hisaabkar.pk/guides/' },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
  ],
};
const breadcrumbSchemaJson = JSON.stringify(breadcrumbSchema);
---

<MainLayout
  title={entry.data.title}
  description={entry.data.summary}
  type="Article"
  schemaData={{ title: entry.data.title, description: entry.data.summary, datePublished: entry.data.pubDate.toISOString() }}
>
  <script type="application/ld+json" set:html={breadcrumbSchemaJson} />
  <article class="max-w-3xl mx-auto px-4 py-10">
    <header class="mb-8">
      <!-- Breadcrumb nav -->
      <nav class="text-xs text-gray-500 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-green-700">Home</a>
        <span class="mx-1">/</span>
        <a href="/guides/" class="hover:text-green-700">Guides</a>
        <span class="mx-1">/</span>
        <span class="text-gray-400 line-clamp-1">{entry.data.title}</span>
      </nav>
      <div class="flex items-center gap-3 mb-4">
        <span class={`text-xs font-semibold uppercase tracking-widest px-2 py-1 rounded ${catColor}`}>
          {entry.data.category}
        </span>
        <span class="text-xs text-gray-400">{entry.data.readTime}</span>
        <time class="text-xs text-gray-400 ml-auto">{pubDateDisplay}</time>
      </div>
      <h1 class="text-3xl font-bold mb-3 text-gray-900 dark:text-white">{entry.data.title}</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">{entry.data.summary}</p>
    </header>

    <div class="guide-content">
      <Content />
    </div>

    <footer class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-700 text-sm text-gray-500">
      <p class="italic">
        Information provided is for educational purposes only and based on publicly available data. Not financial or legal advice. Verify current figures at official sources (FBR, SBP, PBS).
      </p>
      <a href="/guides" class="inline-block mt-4 text-green-700 hover:underline font-medium">← Back to all guides</a>
    </footer>
  </article>
</MainLayout>

<style is:global>
  .guide-content {
    color: #374151;
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  /* Paragraphs */
  .guide-content p {
    margin-top: 0;
    margin-bottom: 1.25em;
  }

  /* Headings */
  .guide-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e5e7eb;
    line-height: 1.3;
  }

  .guide-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .guide-content h4 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: #111827;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  /* Strong / bold */
  .guide-content strong {
    font-weight: 700;
    color: #111827;
  }

  /* Links */
  .guide-content a {
    color: #16a34a;
    font-weight: 500;
    text-decoration: none;
  }
  .guide-content a:hover {
    text-decoration: underline;
  }

  /* Lists */
  .guide-content ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25em;
  }
  .guide-content ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25em;
  }
  .guide-content li {
    margin-bottom: 0.4em;
    color: #374151;
  }

  /* Blockquote */
  .guide-content blockquote {
    border-left: 4px solid #16a34a;
    background: #f0fdf4;
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 0.5rem 0.5rem 0;
    color: #374151;
    font-style: normal;
  }

  /* Tables */
  .guide-content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    margin-bottom: 1.5em;
  }
  .guide-content thead {
    background: #f3f4f6;
  }
  .guide-content th {
    padding: 0.625rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #111827;
    border: 1px solid #e5e7eb;
  }
  .guide-content td {
    padding: 0.625rem 1rem;
    border: 1px solid #e5e7eb;
    color: #374151;
  }
  .guide-content tbody tr:nth-child(even) {
    background: #f9fafb;
  }

  /* Inline code */
  .guide-content code {
    background: #f3f4f6;
    color: #16a34a;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  /* Horizontal rule */
  .guide-content hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }

  /* Dark mode overrides */
  .dark .guide-content {
    color: #d1d5db;
  }
  .dark .guide-content h2,
  .dark .guide-content h3,
  .dark .guide-content h4,
  .dark .guide-content strong {
    color: #f9fafb;
  }
  .dark .guide-content h2 {
    border-bottom-color: #374151;
  }
  .dark .guide-content a {
    color: #4ade80;
  }
  .dark .guide-content li,
  .dark .guide-content td {
    color: #d1d5db;
  }
  .dark .guide-content blockquote {
    background: rgba(22, 163, 74, 0.1);
    color: #d1d5db;
  }
  .dark .guide-content thead {
    background: #1f2937;
  }
  .dark .guide-content th {
    color: #f9fafb;
    border-color: #374151;
  }
  .dark .guide-content td {
    border-color: #374151;
  }
  .dark .guide-content tbody tr:nth-child(even) {
    background: #1f2937;
  }
  .dark .guide-content code {
    background: #1f2937;
    color: #4ade80;
  }
  .dark .guide-content hr {
    border-top-color: #374151;
  }
</style>
