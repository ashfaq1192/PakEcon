---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Finance Guides - PakEcon.ai" description="Comprehensive guides on Pakistani taxation, investment, and financial planning.">
  <section class="py-12 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Finance Guides</h1>
      <p class="text-xl text-gray-600 mb-8">
        Learn about Pakistani taxation, investment, and financial planning
      </p>

      <div class="space-y-6">
        <!-- Guide Cards -->
        <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
          <div class="p-6">
            <span class="text-xs font-semibold text-green-600 uppercase tracking-wider">Taxation</span>
            <h2 class="text-xl font-bold text-gray-900 mt-2 mb-2">
              Complete Guide to FBR 2026 Tax Slabs
            </h2>
            <p class="text-gray-600 mb-4">
              Understanding the new income tax brackets, exemptions, and filing requirements for 2026
            </p>
            <a href="#" class="text-green-600 hover:text-green-700 font-medium">Read Guide →</a>
          </div>
        </article>

        <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
          <div class="p-6">
            <span class="text-xs font-semibold text-blue-600 uppercase tracking-wider">Policy</span>
            <h2 class="text-xl font-bold text-gray-900 mt-2 mb-2">
              Digital Nation Act: Benefits for Freelancers
            </h2>
            <p class="text-gray-600 mb-4">
              How the 2026 Digital Nation Act provides tax credits and incentives for IT professionals
            </p>
            <a href="#" class="text-green-600 hover:text-green-700 font-medium">Read Guide →</a>
          </div>
        </article>

        <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
          <div class="p-6">
            <span class="text-xs font-semibold text-purple-600 uppercase tracking-wider">Investment</span>
            <h2 class="text-xl font-bold text-gray-900 mt-2 mb-2">
              Investing in Pakistan: A Beginner's Guide
            </h2>
            <p class="text-gray-600 mb-4">
              Understanding the Pakistani stock market, mutual funds, and government bonds
            </p>
            <a href="#" class="text-green-600 hover:text-green-700 font-medium">Read Guide →</a>
          </div>
        </article>

        <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
          <div class="p-6">
            <span class="text-xs font-semibold text-orange-600 uppercase tracking-wider">Inflation</span>
            <h2 class="text-xl font-bold text-gray-900 mt-2 mb-2">
              Understanding Pakistan's CPI and Its Impact
            </h2>
            <p class="text-gray-600 mb-4">
              How the Consumer Price Index is calculated and what it means for your finances
            </p>
            <a href="#" class="text-green-600 hover:text-green-700 font-medium">Read Guide →</a>
          </div>
        </article>

        <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
          <div class="p-6">
            <span class="text-xs font-semibold text-red-600 uppercase tracking-wider">Remittance</span>
            <h2 class="text-xl font-bold text-gray-900 mt-2 mb-2">
              Remittances: A Guide for the Pakistani Diaspora
            </h2>
            <p class="text-gray-600 mb-4">
              Best practices for sending money to Pakistan and understanding exchange rates
            </p>
            <a href="#" class="text-green-600 hover:text-green-700 font-medium">Read Guide →</a>
          </div>
        </article>

        <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
          <div class="p-6">
            <span class="text-xs font-semibold text-teal-600 uppercase tracking-wider">Banking</span>
            <h2 class="text-xl font-bold text-gray-900 mt-2 mb-2">
              RAAST: Pakistan's Digital Payment System Explained
            </h2>
            <p class="text-gray-600 mb-4">
              How to use RAAST for instant bank-to-bank transfers and bill payments
            </p>
            <a href="#" class="text-green-600 hover:text-green-700 font-medium">Read Guide →</a>
          </div>
        </article>
      </div>

      <!-- More Coming Soon -->
      <div class="mt-12 text-center p-8 bg-gray-100 rounded-lg">
        <h3 class="text-xl font-semibold text-gray-900 mb-2">More Guides Coming Soon</h3>
        <p class="text-gray-600">
          We're constantly adding new guides. Subscribe to our newsletter for updates.
        </p>
      </div>
    </div>
  </section>
</MainLayout>
