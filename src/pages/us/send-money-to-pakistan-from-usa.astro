            <td class="px-4 py-4 text-center">~$4–6</td>
            <td class="px-4 py-4 text-center">1–2 days</td>
            <td class="px-4 py-4 text-center">Bank account</td>
          </tr>
          <tr>
            <td class="px-4 py-4">
              <div class="font-bold text-gray-900 dark:text-white">Remitly</div>
              <div class="text-xs text-blue-600 dark:text-blue-400 font-medium">⚡ Fastest delivery</div>
            </td>
            <td class="px-4 py-4 text-center text-yellow-700 dark:text-yellow-400 font-semibold">~1–2% below mid-market</td>
            <td class="px-4 py-4 text-center">$0–4 (promo varies)</td>
            <td class="px-4 py-4 text-center">Minutes–same day</td>
            <td class="px-4 py-4 text-center">Bank + mobile wallet</td>
          </tr>
          <tr>
            <td class="px-4 py-4">
              <div class="font-bold text-gray-900 dark:text-white">ACE Money Transfer</div>
              <div class="text-xs text-gray-500 font-medium">🏆 Popular in Pakistani community</div>
            </td>
            <td class="px-4 py-4 text-center text-yellow-700 dark:text-yellow-400 font-semibold">~1–2% below mid-market</td>
            <td class="px-4 py-4 text-center">~$1–3</td>
            <td class="px-4 py-4 text-center">Same day</td>
            <td class="px-4 py-4 text-center">Bank + cash pickup</td>
          </tr>
          <tr>
            <td class="px-4 py-4">
              <div class="font-bold text-gray-900 dark:text-white">Western Union</div>
            </td>
            <td class="px-4 py-4 text-center text-red-600 dark:text-red-400 font-semibold">~2–3% below mid-market</td>
            <td class="px-4 py-4 text-center">$5–10</td>
            <td class="px-4 py-4 text-center">Minutes (cash)</td>
            <td class="px-4 py-4 text-center">Cash pickup + bank</td>
          </tr>
          <tr>
            <td class="px-4 py-4">
              <div class="font-bold text-gray-900 dark:text-white">Xoom (PayPal)</div>
            </td>
            <td class="px-4 py-4 text-center text-yellow-700 dark:text-yellow-400 font-semibold">~1.5–2.5% below</td>
            <td class="px-4 py-4 text-center">$0–5</td>
            <td class="px-4 py-4 text-center">1–2 days</td>
            <td class="px-4 py-4 text-center">Bank account</td>
          </tr>
          <tr>
            <td class="px-4 py-4">
              <div class="font-bold text-gray-900 dark:text-white">Bank Wire (SWIFT)</div>
              <div class="text-xs text-purple-600 dark:text-purple-400 font-medium">💼 Best for large amounts</div>
            </td>
            <td class="px-4 py-4 text-center text-green-700 dark:text-green-400 font-semibold">~0.5–1% below</td>
            <td class="px-4 py-4 text-center">$25–45 flat</td>
            <td class="px-4 py-4 text-center">2–5 days</td>
            <td class="px-4 py-4 text-center">Bank account only</td>
          </tr>
          <tr class="bg-blue-50 dark:bg-blue-900/10">
