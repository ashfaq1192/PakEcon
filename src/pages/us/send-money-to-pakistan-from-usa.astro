            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Service</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Rate vs Interbank</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Fee (approx.)</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Speed</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Delivery</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
