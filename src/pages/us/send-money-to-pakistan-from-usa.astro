              <div class="font-bold text-gray-900 dark:text-white">Roshan Digital Account</div>
              <div class="text-xs text-blue-700 dark:text-blue-400 font-medium">🇵🇰 For RDA holders</div>
            </td>
            <td class="px-4 py-4 text-center text-green-700 dark:text-green-400 font-semibold">Near-interbank</td>
            <td class="px-4 py-4 text-center">Your bank's wire fee</td>
            <td class="px-4 py-4 text-center">Same day–24h</td>
            <td class="px-4 py-4 text-center">RDA → any Pakistani bank</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- PKR received comparison -->
    <div class="p-5 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700 mb-10">
      <h3 class="font-bold text-gray-900 dark:text-white mb-3">How Much PKR Does Your Family Receive? (Sending $500)</h3>
      <p class="text-xs text-gray-500 mb-4">Based on SBP rate of ~PKR 278/USD. Amounts are estimates — use your remittance service's calculator for exact figures on the day you send.</p>
      <div class="space-y-3">
        {[
          { name: 'Wise', pct: 99.5, color: 'bg-green-500' },
          { name: 'Remitly', pct: 98.5, color: 'bg-blue-500' },
          { name: 'ACE Money Transfer', pct: 98, color: 'bg-teal-500' },
          { name: 'Xoom', pct: 97.5, color: 'bg-yellow-500' },
          { name: 'Western Union', pct: 97, color: 'bg-orange-500' },
        ].map(s => {
          const pkr = Math.round(500 * 278 * s.pct / 100);
          return (
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="font-medium text-gray-800 dark:text-gray-200">{s.name}</span>
                <span class="text-gray-600 dark:text-gray-400 font-mono">≈ PKR {pkr.toLocaleString()}</span>
              </div>
              <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                <div class={`${s.color} h-2 rounded-full`} style={`width: ${s.pct}%`}></div>
              </div>
            </div>
          );
        })}
      </div>
      <p class="text-xs text-gray-400 mt-3">*Live calculations shown — update your currency converter above for today's exact rates.</p>
    </div>

    <!-- Our tool CTA -->
    <div class="p-5 border-2 border-green-300 bg-green-50 dark:border-green-700 dark:bg-green-900/20 rounded-xl mb-10">
      <h3 class="font-bold text-green-900 dark:text-green-300 mb-2">Calculate Your Remittance with Live Rates</h3>
      <p class="text-sm text-green-800 dark:text-green-400 mb-3">
        Use HisaabKar.pk's remittance calculator to see exactly how much PKR your family receives based on today's SBP interbank rate.
      </p>
      <a href="/tools/remittance-calculator/" class="inline-flex items-center gap-2 bg-green-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-green-800 transition">
