---
export const prerender = true;
import MainLayout from '../layouts/MainLayout.astro';
import TaxOptimizer from '../components/tools/TaxOptimizer.astro';
import MandiTable from '../components/tools/MandiTable.astro';
import Icon from '../components/ui/Icon.astro';
import ScrollReveal from '../components/ui/ScrollReveal.astro';
import { getCollection } from 'astro:content';

// Latest real blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Financial tools — 8 core tools, no EOBI / Electricity / Zakat / National Savings
const financialTools = [
  {
    href: '/#tax-calculator',
    emoji: '📊',
    title: 'Income Tax Calculator',
    desc: 'Calculate your FBR 2026 tax liability instantly — salaried, freelancer, or business.',
    tag: 'Tax',
    gradient: 'from-green-500 to-emerald-600',
    tagColor: 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400',
  },
  {
    href: '/tools/salary-slip-generator',
    emoji: '📋',
    title: 'Create Salary Slip PDF',
    desc: 'Generate a professional salary slip with auto FBR tax deduction. Download as PDF.',
    tag: 'Tax',
    gradient: 'from-teal-500 to-green-600',
    tagColor: 'bg-teal-100 text-teal-700 dark:bg-teal-900/40 dark:text-teal-400',
  },
  {
    href: '/tools/property-stamp-duty-calculator',
    emoji: '🏠',
    title: 'Stamp Duty Calculator',
    desc: 'Calculate property transfer stamp duty by province — filer vs non-filer rates.',
    tag: 'Property',
    gradient: 'from-orange-500 to-amber-600',
    tagColor: 'bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-400',
  },
  {
    href: '/tools/gold-price-calculator-pakistan',
    emoji: '🪙',
    title: 'Gold Price Calculator',
    desc: 'Live 24K gold rates in PKR per tola & gram. Portfolio value & scenario analysis.',
    tag: 'Markets',
    gradient: 'from-yellow-500 to-amber-500',
    tagColor: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-400',
  },
  {
    href: '/tools/currency-converter',
    emoji: '💱',
    title: 'Currency Converter',
    desc: 'Convert PKR to USD, EUR, GBP & more using live SBP interbank rates + 30-day chart.',
    tag: 'Markets',
    gradient: 'from-blue-500 to-cyan-600',
    tagColor: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400',
  },
  {
    href: '/tools/pakistan-inflation-calculator',
    emoji: '📈',
    title: 'Inflation Impact Calculator',
    desc: "See how Pakistan's inflation has eroded purchasing power using PBS CPI data 2015–2026.",
    tag: 'Markets',
    gradient: 'from-red-500 to-rose-600',
    tagColor: 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400',
  },
  {
    href: '/tools/loan-emi-calculator',
    emoji: '🏦',
    title: 'Loan & EMI Calculator',
    desc: 'Calculate monthly instalments for conventional loans and Islamic Murabaha financing.',
    tag: 'Finance',
    gradient: 'from-purple-500 to-indigo-600',
    tagColor: 'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400',
  },
  {
    href: '/tools/remittance-calculator',
    emoji: '💸',
    title: 'Remittance Calculator',
    desc: 'Convert USD, GBP, AED & 5 more currencies to PKR using live SBP rates.',
    tag: 'Finance',
    gradient: 'from-violet-500 to-purple-600',
    tagColor: 'bg-violet-100 text-violet-700 dark:bg-violet-900/40 dark:text-violet-400',
  },
];

const categoryIconColors: Record<string, string> = {
  market_insight: 'from-green-500 to-emerald-600',
  weekly_digest:  'from-purple-500 to-indigo-600',
  budget_alert:   'from-red-500 to-rose-600',
  policy_update:  'from-blue-500 to-indigo-600',
};

const categoryEmoji: Record<string, string> = {
  market_insight: '📊',
  weekly_digest:  '📰',
  budget_alert:   '🏛️',
  policy_update:  '📋',
};
---

<MainLayout title="HisaabKar.pk — Pakistan Finance & Utility Hub" description="Free Pakistani finance tools: tax calculator, gold rate, electricity bill, zakat, currency converter, salary slip and more. Real-time economic data.">

  <!-- ═══ HERO ═══ -->
  <section class="bg-gradient-to-br from-green-600 via-green-700 to-emerald-800 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <!-- Left: copy -->
        <div>
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded-full mb-5 text-sm text-green-100 font-medium">
            🇵🇰 Pakistan's Free Finance Hub
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 leading-tight">
            Pakistan's Free<br/>
            <span class="text-green-200">Finance Hub</span>
          </h1>
          <p class="text-lg text-green-100 mb-8 max-w-lg leading-relaxed">
            Pakistan's free finance hub — taxes, gold rates, bills, currency & AI-powered economic insights, all in one place.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="#tax-calculator" class="inline-flex items-center gap-2 bg-white text-green-700 font-semibold py-3 px-6 rounded-xl hover:bg-green-50 transition-all hover:scale-105 shadow-lg">
              📊 Calculate Tax
            </a>
            <a href="/blog" class="inline-flex items-center gap-2 bg-green-800/50 backdrop-blur-sm text-white font-semibold py-3 px-6 rounded-xl hover:bg-green-900/60 transition-all border border-green-500/30">
              📰 Latest Insights
            </a>
            <a href="/guides" class="inline-flex items-center gap-2 bg-green-800/50 backdrop-blur-sm text-white font-semibold py-3 px-6 rounded-xl hover:bg-green-900/60 transition-all border border-green-500/30">
              📚 Finance Guides
            </a>
          </div>
        </div>
        <!-- Right: key indicators -->
        <div class="hidden lg:block">
          <div class="relative bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 shadow-2xl">
            <div class="flex items-center justify-between mb-4">
              <p class="text-xs text-emerald-300 uppercase tracking-widest font-bold">Key Economic Indicators</p>
              <span class="flex items-center gap-1.5 text-xs text-white/70 bg-white/15 border border-white/20 px-2 py-0.5 rounded-full font-medium">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse inline-block"></span>
                Reference data
              </span>
            </div>
            <div class="space-y-2.5" id="indicators-list">
              <!-- USD/PKR -->
              <div class="indicator-card opacity-0 flex items-center justify-between bg-white/10 border border-white/15 rounded-xl px-4 py-3
                          hover:bg-white/20 hover:border-white/30 hover:-translate-y-px transition-all duration-200 cursor-default group
                          border-l-[3px] border-l-sky-400">
                <div class="flex items-center gap-2.5">
                  <span class="w-2 h-2 rounded-full bg-sky-400 shrink-0"></span>
                  <span class="text-sm font-medium text-white/90">USD/PKR (Interbank)</span>
                </div>
                <div class="text-right">
                  <span id="ind-usd" class="font-bold text-sky-300 text-base block leading-tight count-up" data-target="278.50" data-decimals="2">—</span>
                  <span class="text-xs text-white/50">SBP</span>
                </div>
              </div>
              <!-- Gold -->
              <div class="indicator-card opacity-0 flex items-center justify-between bg-white/10 border border-white/15 rounded-xl px-4 py-3
                          hover:bg-white/20 hover:border-white/30 hover:-translate-y-px transition-all duration-200 cursor-default group
                          border-l-[3px] border-l-amber-400">
                <div class="flex items-center gap-2.5">
                  <span class="w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>
                  <span class="text-sm font-medium text-white/90">Gold 24K / Tola</span>
                </div>
                <div class="text-right">
                  <span id="ind-gold" class="font-bold text-amber-300 text-base block leading-tight count-up" data-target="524000" data-prefix="PKR " data-decimals="0">—</span>
                  <span class="text-xs text-white/50">PMEX</span>
                </div>
              </div>
              <!-- Petrol -->
              <div class="indicator-card opacity-0 flex items-center justify-between bg-white/10 border border-white/15 rounded-xl px-4 py-3
                          hover:bg-white/20 hover:border-white/30 hover:-translate-y-px transition-all duration-200 cursor-default group
                          border-l-[3px] border-l-orange-400">
                <div class="flex items-center gap-2.5">
                  <span class="w-2 h-2 rounded-full bg-orange-400 shrink-0"></span>
                  <span class="text-sm font-medium text-white/90">Petrol (92 RON)</span>
                </div>
                <div class="text-right">
                  <span id="ind-petrol" class="font-bold text-orange-300 text-base block leading-tight count-up" data-target="321.17" data-prefix="PKR " data-decimals="2">—</span>
                  <span class="text-xs text-white/50">OGRA</span>
                </div>
              </div>
              <!-- CPI -->
              <div class="indicator-card opacity-0 flex items-center justify-between bg-white/10 border border-white/15 rounded-xl px-4 py-3
                          hover:bg-white/20 hover:border-white/30 hover:-translate-y-px transition-all duration-200 cursor-default group
                          border-l-[3px] border-l-rose-400">
                <div class="flex items-center gap-2.5">
                  <span class="w-2 h-2 rounded-full bg-rose-400 shrink-0"></span>
                  <span id="ind-cpi-label" class="text-sm font-medium text-white/90">CPI Inflation</span>
                </div>
                <div class="text-right">
                  <span id="ind-cpi" class="font-bold text-rose-300 text-base block leading-tight count-up" data-target="1.5" data-suffix="% YoY" data-decimals="1">—</span>
                  <span class="text-xs text-white/50">PBS</span>
                </div>
              </div>
              <!-- Policy Rate -->
              <div class="indicator-card opacity-0 flex items-center justify-between bg-white/10 border border-white/15 rounded-xl px-4 py-3
                          hover:bg-white/20 hover:border-white/30 hover:-translate-y-px transition-all duration-200 cursor-default group
                          border-l-[3px] border-l-violet-400">
                <div class="flex items-center gap-2.5">
                  <span class="w-2 h-2 rounded-full bg-violet-400 shrink-0"></span>
                  <span class="text-sm font-medium text-white/90">SBP Policy Rate</span>
                </div>
                <div class="text-right">
                  <span id="ind-policy" class="font-bold text-violet-300 text-base block leading-tight count-up" data-target="12.0" data-suffix="%" data-decimals="1">—</span>
                  <span class="text-xs text-white/50">SBP MPC</span>
                </div>
              </div>
            </div>
            <p class="text-xs text-white/30 mt-3 text-right">Figures are indicative — verify at source</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TOOLS GRID ═══ -->
  <ScrollReveal animation="fade-in-up" delay={100} class="py-14 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Free Financial Tools</h2>
        <p class="text-gray-500 dark:text-gray-400">Built for Pakistan's economy — no signup, no cost</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {financialTools.map((tool) => (
          <a
            href={tool.href}
            class="group bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
          >
            <!-- Gradient icon area -->
            <div class={`h-24 bg-gradient-to-br ${tool.gradient} flex items-center justify-center`}>
              <span class="text-4xl">{tool.emoji}</span>
            </div>
            <!-- Content -->
            <div class="p-4">
              <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${tool.tagColor}`}>{tool.tag}</span>
              <h3 class="text-sm font-bold text-gray-900 dark:text-white mt-2 mb-1 group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors leading-snug">
                {tool.title}
              </h3>
              <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">{tool.desc}</p>
              <p class="text-xs font-semibold text-green-600 dark:text-green-400 mt-3">Use Tool →</p>
            </div>
          </a>
        ))}
      </div>
      <!-- Utility tools — same card style -->
      <div class="mt-5 grid grid-cols-1 sm:grid-cols-3 gap-5">
        {[
          {
            href: '/tools/document-converter',
            emoji: '📄',
            title: 'Document Converter',
            desc: 'Convert Word, Excel and PowerPoint files to PDF instantly — no upload to servers.',
            tag: 'Utility',
            gradient: 'from-slate-500 to-gray-600',
            tagColor: 'bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-400',
          },
          {
            href: '/utilities#age-calculator',
            emoji: '🎂',
            title: 'Age Calculator',
            desc: 'Calculate your exact age in years, months, and days from your date of birth.',
            tag: 'Utility',
            gradient: 'from-pink-500 to-rose-500',
            tagColor: 'bg-pink-100 text-pink-700 dark:bg-pink-900/40 dark:text-pink-400',
          },
          {
            href: '/utilities#image-resizer',
            emoji: '🖼️',
            title: 'Image Resizer',
            desc: 'Resize and compress images to any dimension — all processing done in your browser.',
            tag: 'Utility',
            gradient: 'from-cyan-500 to-sky-600',
            tagColor: 'bg-cyan-100 text-cyan-700 dark:bg-cyan-900/40 dark:text-cyan-400',
          },
        ].map((tool) => (
          <a
            href={tool.href}
            class="group bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
          >
            <div class={`h-24 bg-gradient-to-br ${tool.gradient} flex items-center justify-center`}>
              <span class="text-4xl">{tool.emoji}</span>
            </div>
            <div class="p-4">
              <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${tool.tagColor}`}>{tool.tag}</span>
              <h3 class="text-sm font-bold text-gray-900 dark:text-white mt-2 mb-1 group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors leading-snug">
                {tool.title}
              </h3>
              <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">{tool.desc}</p>
              <p class="text-xs font-semibold text-green-600 dark:text-green-400 mt-3">Use Tool →</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </ScrollReveal>

  <!-- ═══ TAX CALCULATOR — tighter padding ═══ -->
  <ScrollReveal animation="fade-in-up" delay={150} id="tax-calculator" class="py-10 bg-white dark:bg-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6">
        <span class="inline-block bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-3">Most Used Tool</span>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-1">
          FBR Income Tax Calculator 2026
        </h2>
        <p class="text-gray-500 dark:text-gray-400 text-sm max-w-xl mx-auto mb-4">
          Calculate your income tax based on the latest FBR slabs, including Digital Nation Act credits for freelancers and IT professionals.
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="https://fbr.gov.pk" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 text-green-700 dark:text-green-400 text-xs font-medium px-3 py-1.5 rounded-full hover:bg-green-100 transition">
            🏛️ FBR Finance Act 2025-26
          </a>
          <span class="inline-flex items-center gap-1.5 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-700 text-purple-700 dark:text-purple-400 text-xs font-medium px-3 py-1.5 rounded-full">
            ✅ Verified by M.Phil Economics, ACCA
          </span>
        </div>
      </div>
      <TaxOptimizer />
    </div>
  </ScrollReveal>

  <!-- ═══ LATEST BLOG POSTS — smaller card banner ═══ -->
  <ScrollReveal animation="fade-in-up" delay={200} class="py-12 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <span class="inline-block bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-2">AI-Powered</span>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Latest Market Insights</h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1 text-green-600 dark:text-green-400 font-medium text-sm hover:underline">
          View all →
        </a>
      </div>

      {latestPosts.length === 0 ? (
        <div class="text-center py-12 text-gray-400">
          <p>First posts coming soon — our AI agent publishes daily.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {latestPosts.map((post) => {
            const gradColor = categoryIconColors[post.data.category] ?? 'from-green-500 to-emerald-600';
            const emoji = categoryEmoji[post.data.category] ?? '📋';
            const dateDisplay = post.data.pubDate.toLocaleDateString('en-PK', { day: 'numeric', month: 'short', year: 'numeric' });
            return (
              <article class="group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <!-- Shorter banner: h-20 instead of h-36 -->
                <div class={`h-20 bg-gradient-to-br ${gradColor} flex items-center px-5 gap-3`}>
                  <span class="text-2xl">{emoji}</span>
                  <span class="text-xs font-semibold text-white/90 uppercase tracking-wider">
                    {post.data.category.replace(/_/g, ' ')}
                  </span>
                  {post.data.delta !== 0 && (
                    <span class={`ml-auto text-xs font-bold ${post.data.delta > 0 ? 'text-red-200' : 'text-green-200'}`}>
                      {post.data.delta > 0 ? '▲' : '▼'} {Math.abs(post.data.delta).toFixed(2)}%
                    </span>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="text-sm font-bold text-gray-900 dark:text-white mb-2 group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors line-clamp-2 leading-snug">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h3>
                  <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2 mb-4 leading-relaxed">{post.data.summary}</p>
                  <div class="flex items-center justify-between">
                    <time class="text-xs text-gray-400">{dateDisplay}</time>
                    <a href={`/blog/${post.id}`} class="text-xs font-semibold text-green-600 dark:text-green-400 hover:underline">Read →</a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
      <div class="text-center mt-5 sm:hidden">
        <a href="/blog" class="text-green-600 dark:text-green-400 font-medium text-sm hover:underline">View all posts →</a>
      </div>
    </div>
  </ScrollReveal>

  <!-- ═══ GOLD & SILVER RATES — no double heading ═══ -->
  <ScrollReveal animation="fade-in-up" delay={250} id="market-data" class="py-12 bg-white dark:bg-gray-800 border-t border-gray-100 dark:border-gray-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6">
        <span class="inline-block bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-2">Live Prices</span>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Gold & Silver Rates</h2>
        <p class="text-gray-500 dark:text-gray-400 text-sm">Live 24K gold and silver prices in PKR, updated daily via international markets</p>
      </div>
      <MandiTable />
    </div>
  </ScrollReveal>

  <!-- ═══ GUIDES TEASER — clear visual separation ═══ -->
  <ScrollReveal animation="fade-in-up" delay={300} class="py-12 bg-gray-50 dark:bg-gray-900 border-t border-gray-100 dark:border-gray-700">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <span class="inline-block bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-2">In-Depth Guides</span>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Learn Pakistani Finance</h2>
        </div>
        <a href="/guides" class="hidden sm:inline-flex items-center gap-1 text-green-600 dark:text-green-400 font-medium text-sm hover:underline">
          All guides →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { href: '/guides/fbr-income-tax-slabs-2026',                        emoji: '🏛️', title: 'FBR Tax Slabs 2026',     cat: 'Taxation',   bg: 'bg-green-50 dark:bg-green-900/20',   border: 'border-green-100 dark:border-green-800' },
          { href: '/guides/investing-in-pakistan-beginners-guide',             emoji: '📈', title: 'Investing in Pakistan',  cat: 'Investment', bg: 'bg-purple-50 dark:bg-purple-900/20', border: 'border-purple-100 dark:border-purple-800' },
          { href: '/guides/remittances-guide-pakistani-diaspora',              emoji: '💸', title: 'Remittances Guide',      cat: 'Remittance', bg: 'bg-blue-50 dark:bg-blue-900/20',     border: 'border-blue-100 dark:border-blue-800' },
          { href: '/guides/digital-nation-act-freelancers-it-professionals',   emoji: '💻', title: 'Digital Nation Act',    cat: 'Policy',     bg: 'bg-indigo-50 dark:bg-indigo-900/20', border: 'border-indigo-100 dark:border-indigo-800' },
        ].map(g => (
          <a href={g.href} class={`group flex items-center gap-4 rounded-2xl p-4 border ${g.bg} ${g.border} hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200`}>
            <span class="text-3xl flex-shrink-0">{g.emoji}</span>
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">{g.cat}</p>
              <p class="text-sm font-bold text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors leading-tight">{g.title}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-5 sm:hidden">
        <a href="/guides" class="text-green-600 dark:text-green-400 font-medium text-sm hover:underline">All guides →</a>
      </div>
    </div>
  </ScrollReveal>

  <!-- ═══ NEWSLETTER CTA ═══ -->
  <ScrollReveal animation="fade-in-up" delay={350} class="py-16 bg-gradient-to-r from-green-600 to-emerald-700 text-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-5">
        <Icon name="envelope" size={16} class="text-green-200" />
        <span class="text-sm font-medium text-green-100">Every Monday Morning</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-3">Weekly Economic Digest</h2>
      <p class="text-green-100 mb-8 text-lg">AI-powered summary of Pakistan's economy — exchange rates, inflation, policy updates. Free, no spam.</p>
      <form id="hero-newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          id="hero-newsletter-email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-xl text-gray-900 focus:ring-2 focus:ring-green-300 focus:outline-none"
        />
        <button type="submit" class="inline-flex items-center justify-center gap-2 bg-green-800 text-white font-semibold py-3 px-6 rounded-xl hover:bg-green-900 transition-colors whitespace-nowrap">
          <Icon name="send" size={16} />
          Subscribe Free
        </button>
      </form>
      <p id="hero-newsletter-msg" class="mt-3 text-green-200 text-sm hidden"></p>
    </div>
  </ScrollReveal>

  <script>
    const heroForm = document.getElementById('hero-newsletter-form') as HTMLFormElement | null;
    const heroMsg = document.getElementById('hero-newsletter-msg');
    heroForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('hero-newsletter-email') as HTMLInputElement;
      const email = emailInput?.value?.trim();
      if (!email) return;
      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json() as { message?: string; error?: string };
        if (heroMsg) {
          heroMsg.textContent = data.message || data.error || 'Done!';
          heroMsg.classList.remove('hidden');
        }
        if (res.ok) {
          emailInput.value = '';
          if (typeof showToast !== 'undefined') showToast({ message: 'Check your email to confirm!', type: 'success' });
        } else if (typeof showToast !== 'undefined') {
          showToast({ message: data.error || 'Subscription failed', type: 'error' });
        }
      } catch {
        if (heroMsg) { heroMsg.textContent = 'Failed — please try again.'; heroMsg.classList.remove('hidden'); }
        if (typeof showToast !== 'undefined') showToast({ message: 'Network error', type: 'error' });
      }
    });
  </script>

  <!-- ═══ INDICATORS: live fetch + staggered entrance + count-up ═══ -->
  <script>
    (function () {
      const cards = Array.from(document.querySelectorAll<HTMLElement>('#indicators-list .indicator-card'));
      if (!cards.length) return;

      // ── Count-up animation ───────────────────────────────────────────────────
      function animateCountUp(el: HTMLElement) {
        const target = parseFloat(el.dataset.target ?? '0');
        if (!target) { el.textContent = (el.dataset.prefix ?? '') + '—' + (el.dataset.suffix ?? ''); return; }
        const decimals = parseInt(el.dataset.decimals ?? '0', 10);
        const prefix = el.dataset.prefix ?? '';
        const suffix = el.dataset.suffix ?? '';
        const duration = 900;
        const start = performance.now();
        function frame(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = prefix + (target * eased).toLocaleString('en-PK', {
            minimumFractionDigits: decimals, maximumFractionDigits: decimals,
          }) + suffix;
          if (progress < 1) requestAnimationFrame(frame);
        }
        requestAnimationFrame(frame);
      }

      // ── Staggered entrance ───────────────────────────────────────────────────
      function runEntrance() {
        cards.forEach((card, i) => {
          setTimeout(() => {
            card.style.transition = 'opacity 400ms ease, transform 400ms ease';
            card.style.transform = 'translateX(0)';
            card.style.opacity = '1';
            const countEl = card.querySelector<HTMLElement>('.count-up');
            if (countEl) animateCountUp(countEl);
          }, i * 130);
        });
      }

      // ── Set initial off-screen position ─────────────────────────────────────
      cards.forEach(card => {
        card.style.transform = 'translateX(32px)';
        card.style.opacity = '0';
      });

      // ── Fetch live data, update targets, then animate ────────────────────────
      async function loadIndicators() {
        try {
          const [fxRes, goldRes, commRes, policyRes] = await Promise.allSettled([
            fetch('/api/exchange-rates?currency=USD'),
            fetch('/api/gold-price'),
            fetch('/api/commodities?commodity=petrol'),
            fetch('/api/policy-rates'),
          ]);

          // USD/PKR
          if (fxRes.status === 'fulfilled' && fxRes.value.ok) {
            const d = await fxRes.value.json() as any;
            const rate = d.rates?.[0]?.rate;
            if (rate) {
              const el = document.getElementById('ind-usd');
              if (el) el.dataset.target = String(rate);
            }
          }

          // Gold per tola
          if (goldRes.status === 'fulfilled' && goldRes.value.ok) {
            const d = await goldRes.value.json() as any;
            const tola = d.goldPerTola;
            if (tola) {
              const el = document.getElementById('ind-gold');
              if (el) el.dataset.target = String(tola);
            }
          }

          // Petrol
          if (commRes.status === 'fulfilled' && commRes.value.ok) {
            const d = await commRes.value.json() as any;
            const price = d.commodities?.[0]?.price;
            if (price) {
              const el = document.getElementById('ind-petrol');
              if (el) el.dataset.target = String(price);
            }
          }

          // CPI + Policy Rate
          if (policyRes.status === 'fulfilled' && policyRes.value.ok) {
            const d = await policyRes.value.json() as any;

            const cpiYoY = d.cpi?.yoy_change;
            if (cpiYoY !== undefined) {
              const el = document.getElementById('ind-cpi');
              if (el) el.dataset.target = String(cpiYoY);
            }
            // Update CPI label with real month (e.g. "2026-02" → "Feb")
            const cpiMonth = d.cpi?.month;
            if (cpiMonth) {
              const label = document.getElementById('ind-cpi-label');
              if (label) {
                const mon = new Date(cpiMonth + '-02').toLocaleDateString('en-PK', { month: 'short' });
                label.textContent = `CPI Inflation (${mon})`;
              }
            }

            const policyRate = d.policyRates?.policy_rate?.rate;
            if (policyRate !== undefined) {
              const el = document.getElementById('ind-policy');
              if (el) el.dataset.target = String(policyRate);
            }
          }
        } catch { /* use fallback data-target values already in HTML */ }

        // Run entrance animation regardless of fetch outcome
        runEntrance();
      }

      // ── Trigger on intersection ──────────────────────────────────────────────
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          observer.disconnect();
          loadIndicators();
        });
      }, { threshold: 0.2 });

      const list = document.getElementById('indicators-list');
      if (list) observer.observe(list);
    })();
  </script>

</MainLayout>
