---
export const prerender = true;
import MainLayout from '../layouts/MainLayout.astro';
import TaxOptimizer from '../components/tools/TaxOptimizer.astro';
import MandiTable from '../components/tools/MandiTable.astro';
import Icon from '../components/ui/Icon.astro';
import ScrollReveal from '../components/ui/ScrollReveal.astro';
import { getCollection } from 'astro:content';

// Latest real blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Tool categories
const toolCategories = [
  {
    label: 'Tax & Salary',
    color: 'green',
    tools: [
      { href: '/#tax-calculator',                         emoji: '📊', title: 'Tax Calculator',     desc: 'FBR 2026 slabs' },
      { href: '/tools/salary-slip-generator',             emoji: '📋', title: 'Salary Slip PDF',    desc: 'Auto tax, PDF' },
      { href: '/tools/eobi-calculator',                   emoji: '👤', title: 'EOBI & PF',          desc: 'Retirement corpus' },
    ],
  },
  {
    label: 'Bills & Zakat',
    color: 'amber',
    tools: [
      { href: '/tools/electricity-bill-calculator',       emoji: '⚡', title: 'Electricity Bill',   desc: 'All 9 DISCOs' },
      { href: '/tools/zakat-calculator',                  emoji: '🌙', title: 'Zakat Calculator',   desc: 'Gold/Silver nisab' },
      { href: '/tools/property-stamp-duty-calculator',    emoji: '🏠', title: 'Stamp Duty',         desc: 'By province' },
    ],
  },
  {
    label: 'Markets & Rates',
    color: 'blue',
    tools: [
      { href: '/tools/gold-price-calculator-pakistan',    emoji: '🥇', title: 'Gold Rate',          desc: 'Live 24K prices' },
      { href: '/tools/currency-converter',                emoji: '💱', title: 'Currency',            desc: 'SBP interbank' },
      { href: '/tools/pakistan-inflation-calculator',     emoji: '📈', title: 'Inflation',           desc: 'PBS CPI 2015–2026' },
    ],
  },
  {
    label: 'Finance',
    color: 'purple',
    tools: [
      { href: '/tools/loan-emi-calculator',               emoji: '🏦', title: 'Loan / EMI',         desc: 'Islamic & conv.' },
      { href: '/tools/remittance-calculator',             emoji: '💸', title: 'Remittance',          desc: 'USD/GBP/AED→PKR' },
      { href: '/tools/national-savings-calculator',       emoji: '🏛️', title: 'National Savings',   desc: 'Behbood, RIC, DSC' },
    ],
  },
  {
    label: 'Utilities',
    color: 'violet',
    tools: [
      { href: '/tools/document-converter',                emoji: '📄', title: 'Doc Converter',      desc: 'Word/Excel→PDF' },
      { href: '/utilities#age-calculator',                emoji: '🎂', title: 'Age Calculator',      desc: 'Exact age & days' },
      { href: '/utilities#image-resizer',                 emoji: '🖼️', title: 'Image Resizer',      desc: 'Resize & compress' },
    ],
  },
];

const categoryColorMap: Record<string, { bg: string; border: string; badge: string; text: string }> = {
  green:  { bg: 'bg-green-50 dark:bg-green-900/10',   border: 'border-green-100 dark:border-green-800',   badge: 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400',   text: 'text-green-700 dark:text-green-400' },
  amber:  { bg: 'bg-amber-50 dark:bg-amber-900/10',   border: 'border-amber-100 dark:border-amber-800',   badge: 'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400',   text: 'text-amber-700 dark:text-amber-400' },
  blue:   { bg: 'bg-blue-50 dark:bg-blue-900/10',     border: 'border-blue-100 dark:border-blue-800',     badge: 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400',       text: 'text-blue-700 dark:text-blue-400' },
  purple: { bg: 'bg-purple-50 dark:bg-purple-900/10', border: 'border-purple-100 dark:border-purple-800', badge: 'bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-400', text: 'text-purple-700 dark:text-purple-400' },
  violet: { bg: 'bg-violet-50 dark:bg-violet-900/10', border: 'border-violet-100 dark:border-violet-800', badge: 'bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-400', text: 'text-violet-700 dark:text-violet-400' },
};

const samplePrices = [
  { commodity: 'Wheat', city: 'Lahore', price: 5200, unit: '40kg', date: '2026-03-15', change: 1.2 },
  { commodity: 'Rice (Basmati)', city: 'Lahore', price: 8500, unit: '40kg', date: '2026-03-15', change: -0.5 },
  { commodity: 'Sugar', city: 'Karachi', price: 180, unit: 'kg', date: '2026-03-15', change: 0 },
  { commodity: 'Flour', city: 'Islamabad', price: 140, unit: 'kg', date: '2026-03-15', change: 2.1 },
  { commodity: 'Tomato', city: 'Peshawar', price: 220, unit: 'kg', date: '2026-03-15', change: -3.5 },
  { commodity: 'Onion', city: 'Multan', price: 160, unit: 'kg', date: '2026-03-15', change: 1.8 },
  { commodity: 'Potato', city: 'Quetta', price: 120, unit: 'kg', date: '2026-03-15', change: 0.5 },
  { commodity: 'Gold (24k)', city: 'National', price: 513000, unit: 'tola', date: '2026-03-17', change: 0.8 },
];

const categoryIconColors: Record<string, string> = {
  market_insight: 'from-green-500 to-emerald-600',
  weekly_digest:  'from-purple-500 to-indigo-600',
  budget_alert:   'from-red-500 to-rose-600',
  policy_update:  'from-blue-500 to-indigo-600',
};
---

<MainLayout title="HisaabKar.pk — Pakistan Finance & Utility Hub" description="Free Pakistani finance tools: tax calculator, gold rate, electricity bill, zakat, currency converter, salary slip and more. Real-time economic data.">

  <!-- ═══ HERO ═══ -->
  <section class="bg-gradient-to-br from-green-600 via-green-700 to-emerald-800 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <!-- Left: copy -->
        <div>
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded-full mb-5 text-sm text-green-100 font-medium">
            🇵🇰 Pakistan's Free Finance Hub
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 leading-tight">
            Hisaab Karein,<br/>
            <span class="text-green-200">Sar Uthaa Karein</span>
          </h1>
          <p class="text-lg text-green-100 mb-8 max-w-lg leading-relaxed">
            Tax calculators, gold rates, electricity bills, currency converter, and AI-powered economic insights — all free, all in one place.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/#tax-calculator" class="inline-flex items-center gap-2 bg-white text-green-700 font-semibold py-3 px-6 rounded-xl hover:bg-green-50 transition-all hover:scale-105 shadow-lg">
              📊 Calculate Tax
            </a>
            <a href="/blog" class="inline-flex items-center gap-2 bg-green-800/50 backdrop-blur-sm text-white font-semibold py-3 px-6 rounded-xl hover:bg-green-900/60 transition-all border border-green-500/30">
              📰 Latest Insights
            </a>
            <a href="/guides" class="inline-flex items-center gap-2 bg-green-800/50 backdrop-blur-sm text-white font-semibold py-3 px-6 rounded-xl hover:bg-green-900/60 transition-all border border-green-500/30">
              📚 Finance Guides
            </a>
          </div>
        </div>
        <!-- Right: live stats card -->
        <div class="hidden lg:block">
          <div class="relative bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 shadow-2xl">
            <p class="text-xs text-green-300 uppercase tracking-widest font-semibold mb-4">Today's Key Indicators</p>
            <div class="space-y-3">
              {[
                { label: '💵 USD/PKR (Interbank)', value: '279.31', badge: '▼ -0.4%', badgeColor: 'text-green-300' },
                { label: '🥇 Gold 24K / Tola',    value: 'PKR 5,13,000', badge: '▲ +0.8%', badgeColor: 'text-red-300' },
                { label: '⛽ Petrol (92 RON)',      value: 'PKR 321.17',   badge: 'Stable', badgeColor: 'text-gray-300' },
                { label: '📊 CPI Inflation (Feb)', value: '7.0% YoY',    badge: 'PBS', badgeColor: 'text-green-300' },
                { label: '🏦 SBP Policy Rate',     value: '12.0%',        badge: 'SBP MPC', badgeColor: 'text-blue-300' },
              ].map(stat => (
                <div class="flex items-center justify-between bg-white/10 rounded-xl px-4 py-3">
                  <span class="text-sm text-green-100">{stat.label}</span>
                  <div class="text-right">
                    <span class="font-bold text-white text-sm block">{stat.value}</span>
                    <span class={`text-xs ${stat.badgeColor}`}>{stat.badge}</span>
                  </div>
                </div>
              ))}
            </div>
            <p class="text-xs text-green-400/60 mt-3 text-right">Source: SBP · OGRA · PBS · As of Mar 2026</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TOOLS GRID ═══ -->
  <ScrollReveal animation="fade-in-up" delay={100} class="py-14 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Free Financial Tools</h2>
        <p class="text-gray-500 dark:text-gray-400">15 tools built for Pakistan's economy — no signup required</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {toolCategories.map((cat) => {
          const c = categoryColorMap[cat.color];
          return (
            <div class={`rounded-2xl border p-4 ${c.bg} ${c.border}`}>
              <p class={`text-xs font-bold uppercase tracking-widest mb-3 px-2 py-1 rounded-full inline-block ${c.badge}`}>
                {cat.label}
              </p>
              <div class="space-y-2">
                {cat.tools.map(tool => (
                  <a
                    href={tool.href}
                    class="flex items-center gap-3 p-3 rounded-xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 hover:border-current hover:shadow-md transition-all duration-200 group"
                  >
                    <span class="text-xl flex-shrink-0">{tool.emoji}</span>
                    <div class="min-w-0">
                      <p class={`text-sm font-semibold group-hover:${c.text} transition-colors text-gray-900 dark:text-white leading-tight`}>{tool.title}</p>
                      <p class="text-xs text-gray-400 dark:text-gray-500 truncate">{tool.desc}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </ScrollReveal>

  <!-- ═══ TAX CALCULATOR ═══ -->
  <ScrollReveal animation="fade-in-up" delay={150} id="tax-calculator" class="py-14 bg-white dark:bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <span class="inline-block bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-3">Most Used Tool</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">
          FBR Income Tax Calculator 2026
        </h2>
        <p class="text-green-600 dark:text-green-400 font-medium mb-3 text-lg" dir="rtl" lang="ur">اپنا ٹیکس یہاں کیلکولیٹ کریں</p>
        <p class="text-gray-500 dark:text-gray-400 max-w-2xl mx-auto mb-5">
          Calculate your income tax based on the latest FBR slabs, including Digital Nation Act credits for freelancers and IT professionals.
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="https://fbr.gov.pk" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 text-green-700 dark:text-green-400 text-xs font-medium px-3 py-1.5 rounded-full hover:bg-green-100 transition">
            🏛️ FBR Finance Act 2025-26
          </a>
          <a href="https://www.sbp.org.pk" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 text-blue-700 dark:text-blue-400 text-xs font-medium px-3 py-1.5 rounded-full hover:bg-blue-100 transition">
            🏦 SBP Interbank Rates
          </a>
          <span class="inline-flex items-center gap-1.5 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-700 text-purple-700 dark:text-purple-400 text-xs font-medium px-3 py-1.5 rounded-full">
            ✅ Verified by M.Phil Economics, ACCA
          </span>
        </div>
      </div>
      <TaxOptimizer />
    </div>
  </ScrollReveal>

  <!-- ═══ LATEST BLOG POSTS ═══ -->
  <ScrollReveal animation="fade-in-up" delay={200} class="py-14 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <div>
          <span class="inline-block bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-2">AI-Generated Daily</span>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Latest Market Insights</h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1 text-green-600 dark:text-green-400 font-medium text-sm hover:underline">
          View all posts →
        </a>
      </div>

      {latestPosts.length === 0 ? (
        <div class="text-center py-16 text-gray-400">
          <p class="text-lg">First posts coming soon — our AI agent publishes daily.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map((post) => {
            const gradColor = categoryIconColors[post.data.category] ?? 'from-green-500 to-emerald-600';
            const dateDisplay = post.data.pubDate.toLocaleDateString('en-PK', { day: 'numeric', month: 'short', year: 'numeric' });
            return (
              <article class="group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class={`h-36 bg-gradient-to-br ${gradColor} flex items-center justify-center`}>
                  <span class="text-4xl opacity-80">
                    {post.data.category === 'market_insight' ? '📊' :
                     post.data.category === 'weekly_digest' ? '📰' :
                     post.data.category === 'budget_alert' ? '🏛️' : '📋'}
                  </span>
                </div>
                <div class="p-5">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider bg-green-50 dark:bg-green-900/30 px-2 py-0.5 rounded">
                      {post.data.category.replace(/_/g, ' ')}
                    </span>
                    {post.data.delta !== 0 && (
                      <span class={`text-xs font-bold ${post.data.delta > 0 ? 'text-red-500' : 'text-green-600'}`}>
                        {post.data.delta > 0 ? '▲' : '▼'} {Math.abs(post.data.delta).toFixed(2)}%
                      </span>
                    )}
                  </div>
                  <h3 class="text-base font-bold text-gray-900 dark:text-white mb-2 group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors line-clamp-2">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h3>
                  <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 mb-3">{post.data.summary}</p>
                  <div class="flex items-center justify-between">
                    <time class="text-xs text-gray-400">{dateDisplay}</time>
                    <a href={`/blog/${post.id}`} class="text-xs font-semibold text-green-600 dark:text-green-400 hover:underline">Read →</a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
      <div class="text-center mt-6 sm:hidden">
        <a href="/blog" class="text-green-600 dark:text-green-400 font-medium text-sm hover:underline">View all posts →</a>
      </div>
    </div>
  </ScrollReveal>

  <!-- ═══ MANDI TABLE ═══ -->
  <ScrollReveal animation="fade-in-up" delay={250} id="market-data" class="py-14 bg-white dark:bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <span class="inline-block bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-2">Live Prices</span>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">Daily Mandi Rates</h2>
        <p class="text-green-600 dark:text-green-400 font-medium text-lg mb-1" dir="rtl" lang="ur">آج کے منڈی ریٹ</p>
        <p class="text-gray-500 dark:text-gray-400 text-sm">Commodity prices across major Pakistani markets, updated daily</p>
      </div>
      <MandiTable prices={samplePrices} loading={false} />
    </div>
  </ScrollReveal>

  <!-- ═══ GUIDES TEASER ═══ -->
  <ScrollReveal animation="fade-in-up" delay={300} class="py-14 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <div>
          <span class="inline-block bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-2">In-Depth Guides</span>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Learn Pakistani Finance</h2>
        </div>
        <a href="/guides" class="hidden sm:inline-flex items-center gap-1 text-green-600 dark:text-green-400 font-medium text-sm hover:underline">
          All guides →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { href: '/guides/fbr-income-tax-slabs-2026',                        emoji: '🏛️', title: 'FBR Tax Slabs 2026',              cat: 'Taxation',   color: 'green' },
          { href: '/guides/investing-in-pakistan-beginners-guide',             emoji: '📈', title: 'Investing in Pakistan',           cat: 'Investment', color: 'purple' },
          { href: '/guides/remittances-guide-pakistani-diaspora',              emoji: '💸', title: 'Remittances Guide',              cat: 'Remittance', color: 'blue' },
          { href: '/guides/digital-nation-act-freelancers-it-professionals',   emoji: '💻', title: 'Digital Nation Act',             cat: 'Policy',     color: 'indigo' },
        ].map(g => (
          <a href={g.href} class="group flex items-center gap-4 bg-white dark:bg-gray-800 rounded-2xl p-4 border border-gray-100 dark:border-gray-700 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
            <span class="text-3xl flex-shrink-0">{g.emoji}</span>
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">{g.cat}</p>
              <p class="text-sm font-bold text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors leading-tight">{g.title}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-5 sm:hidden">
        <a href="/guides" class="text-green-600 dark:text-green-400 font-medium text-sm hover:underline">All guides →</a>
      </div>
    </div>
  </ScrollReveal>

  <!-- ═══ NEWSLETTER CTA ═══ -->
  <ScrollReveal animation="fade-in-up" delay={350} class="py-16 bg-gradient-to-r from-green-600 to-emerald-700 text-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-5">
        <Icon name="envelope" size={16} class="text-green-200" />
        <span class="text-sm font-medium text-green-100">Every Monday Morning</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-3">Weekly Economic Digest</h2>
      <p class="text-green-100 mb-8 text-lg">AI-powered summary of Pakistan's economy — exchange rates, inflation, policy updates. Free, no spam.</p>
      <form id="hero-newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          id="hero-newsletter-email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-xl text-gray-900 focus:ring-2 focus:ring-green-300 focus:outline-none"
        />
        <button type="submit" class="inline-flex items-center justify-center gap-2 bg-green-800 text-white font-semibold py-3 px-6 rounded-xl hover:bg-green-900 transition-colors whitespace-nowrap">
          <Icon name="send" size={16} />
          Subscribe Free
        </button>
      </form>
      <p id="hero-newsletter-msg" class="mt-3 text-green-200 text-sm hidden"></p>
    </div>
  </ScrollReveal>

  <script>
    const heroForm = document.getElementById('hero-newsletter-form') as HTMLFormElement | null;
    const heroMsg = document.getElementById('hero-newsletter-msg');
    heroForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('hero-newsletter-email') as HTMLInputElement;
      const email = emailInput?.value?.trim();
      if (!email) return;
      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json() as { message?: string; error?: string };
        if (heroMsg) {
          heroMsg.textContent = data.message || data.error || 'Done!';
          heroMsg.classList.remove('hidden');
        }
        if (res.ok) {
          emailInput.value = '';
          if (typeof showToast !== 'undefined') showToast({ message: 'Check your email to confirm!', type: 'success' });
        } else if (typeof showToast !== 'undefined') {
          showToast({ message: data.error || 'Subscription failed', type: 'error' });
        }
      } catch {
        if (heroMsg) { heroMsg.textContent = 'Failed — please try again.'; heroMsg.classList.remove('hidden'); }
        if (typeof showToast !== 'undefined') showToast({ message: 'Network error', type: 'error' });
      }
    });
  </script>

</MainLayout>
