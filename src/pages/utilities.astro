---
import MainLayout from '../layouts/MainLayout.astro';
import AgeCalculator from '../components/tools/AgeCalculator.astro';
import PdfConverter from '../components/tools/PdfConverter.astro';
import ImageResizer from '../components/tools/ImageResizer.astro';
---

<MainLayout title="Utilities - PakEcon.ai" description="Free online tools for age calculation, PDF conversion, and image resizing.">
  <section class="py-12 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Online Utilities</h1>
      <p class="text-xl text-gray-600 mb-8">
        Free, client-side tools that run entirely in your browser. No data is uploaded to any server.
      </p>

      <!-- Tools Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        <a href="#age-calculator" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition group">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-200 transition">
            <span class="text-2xl">🎂</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Age Calculator</h3>
          <p class="text-sm text-gray-600">Calculate your exact age in years, months, and days</p>
        </a>

        <a href="#pdf-converter" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition group">
          <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-red-200 transition">
            <span class="text-2xl">📄</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">PDF to Images</h3>
          <p class="text-sm text-gray-600">Convert PDF pages to PNG, JPEG, or WebP images</p>
        </a>

        <a href="#image-resizer" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition group">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-purple-200 transition">
            <span class="text-2xl">🖼️</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Image Resizer</h3>
          <p class="text-sm text-gray-600">Resize and compress images in your browser</p>
        </a>
      </div>

      <!-- Privacy Notice -->
      <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-12">
        <div class="flex items-start">
          <span class="text-green-600 mr-3 mt-0.5">🔒</span>
          <div>
            <h3 class="font-semibold text-green-800 mb-2">100% Client-Side Privacy</h3>
            <p class="text-green-700 text-sm">
              All tools on this page run entirely in your browser using JavaScript. Your files are never uploaded to any server.
              Everything stays on your device, ensuring complete privacy and security.
            </p>
          </div>
        </div>
      </div>

      <!-- Age Calculator Tool -->
      <section id="age-calculator" class="mb-16 scroll-mt-8">
        <AgeCalculator />
      </section>

      <!-- PDF Converter Tool -->
      <section id="pdf-converter" class="mb-16 scroll-mt-8">
        <PdfConverter />
      </section>

      <!-- Image Resizer Tool -->
      <section id="image-resizer" class="mb-16 scroll-mt-8">
        <ImageResizer />
      </section>
    </div>
  </section>
</MainLayout>
