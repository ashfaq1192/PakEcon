---
export const prerender = true;
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/ui/Icon.astro';
import ScrollReveal from '../components/ui/ScrollReveal.astro';
import AgeCalculator from '../components/tools/AgeCalculator.astro';
import PdfConverter from '../components/tools/PdfConverter.astro';
import ImageResizer from '../components/tools/ImageResizer.astro';
---

<MainLayout title="Utilities - HisaabKar.pk" description="Free online tools for age calculation, PDF conversion, and image resizing.">
  <!-- Hero Section -->
  <ScrollReveal animation="fade-in" class="bg-gradient-to-br from-blue-600 to-indigo-700 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full mb-6">
        <Icon name="lightbulb" size={16} class="text-blue-200" />
        <span class="text-sm font-medium text-blue-100 uppercase tracking-wider">Online Utilities</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Free, Client-Side<br />
        <span class="text-blue-200">Browser Tools</span>
      </h1>
      <p class="text-xl text-blue-100 max-w-2xl mx-auto">
        All tools run entirely in your browser. No data is uploaded to any server.
      </p>
    </div>
  </ScrollReveal>

  <!-- Tools Grid -->
  <ScrollReveal animation="fade-in-up" delay={100} class="py-12 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4 text-center">
        Available Tools
      </h2>
      <p class="text-gray-600 dark:text-gray-400 text-center mb-10 max-w-2xl mx-auto">
        Free, secure utilities that work 100% in your browser
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            href: '#age-calculator',
            icon: 'calendar',
            emoji: '🎂',
            title: 'Age Calculator',
            desc: 'Calculate your exact age in years, months, and days',
            cardBg: 'from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/40',
            iconClass: 'text-blue-600 dark:text-blue-400',
          },
          {
            href: '#pdf-converter',
            icon: 'download',
            emoji: '📄',
            title: 'PDF to Images',
            desc: 'Convert PDF pages to PNG, JPEG, or WebP images',
            cardBg: 'from-red-100 to-red-200 dark:from-red-900/30 dark:to-red-800/40',
            iconClass: 'text-red-600 dark:text-red-400',
          },
          {
            href: '#image-resizer',
            icon: 'upload',
            emoji: '🖼️',
            title: 'Image Resizer',
            desc: 'Resize and compress images in your browser',
            cardBg: 'from-purple-100 to-purple-200 dark:from-purple-900/30 dark:to-purple-800/40',
            iconClass: 'text-purple-600 dark:text-purple-400',
          },
        ].map((tool, index) => (
          <ScrollReveal
            key={tool.href}
            animation="fade-in-up"
            delay={200 + index * 100}
          >
            <a
              href={tool.href}
              class="group block bg-white dark:bg-gray-800 rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-200 dark:border-gray-700"
            >
              <div class={`h-32 bg-gradient-to-br ${tool.cardBg} flex flex-col items-center justify-center gap-2 transition-transform duration-300 group-hover:scale-110`}>
                <span class="text-4xl" role="img" aria-hidden="true">{tool.emoji}</span>
                <Icon name={tool.icon as any} size={20} class={tool.iconClass} />
              </div>
              <div class="p-6 text-center">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2 transition-colors">
                  {tool.title}
                </h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">
                  {tool.desc}
                </p>
              </div>
            </a>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </ScrollReveal>

  <!-- Privacy Notice -->
  <ScrollReveal animation="fade-in-up" delay={500} class="py-12 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-green-50 to-emerald-100 dark:from-green-900/30 dark:to-emerald-900/30 rounded-2xl p-8 border-2 border-green-200 dark:border-green-800">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-green-600 dark:bg-green-500 rounded-xl flex items-center justify-center flex-shrink-0">
            <Icon name="shield" size={24} class="text-white" />
          </div>
          <div>
            <h3 class="text-xl font-bold text-green-800 dark:text-green-200 mb-2">
              100% Client-Side Privacy
            </h3>
            <p class="text-green-700 dark:text-green-300 text-base leading-relaxed">
              All tools on this page run entirely in your browser using JavaScript.
              Your files are never uploaded to any server.
            </p>
            <p class="text-green-700 dark:text-green-300 text-base leading-relaxed mt-3">
              Everything stays on your device, ensuring complete privacy and security.
            </p>
          </div>
        </div>
      </div>
    </div>
  </ScrollReveal>

  <!-- Age Calculator Tool -->
  <ScrollReveal animation="fade-in-up" delay={600} id="age-calculator" class="py-12 bg-white dark:bg-gray-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2 bg-blue-100 dark:bg-blue-900/30 px-4 py-2 rounded-full mb-4">
          <Icon name="calendar" size={20} class="text-blue-600 dark:text-blue-400" />
          <span class="text-sm font-semibold text-blue-800 dark:text-blue-200">Age Calculator</span>
        </div>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
          Calculate Your Exact Age
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Find out your precise age in years, months, and days
        </p>
      </div>
      <AgeCalculator />
    </div>
  </ScrollReveal>

  <!-- PDF Converter Tool -->
  <ScrollReveal animation="fade-in-up" delay={700} id="pdf-converter" class="py-12 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2 bg-red-100 dark:bg-red-900/30 px-4 py-2 rounded-full mb-4">
          <Icon name="download" size={20} class="text-red-600 dark:text-red-400" />
          <span class="text-sm font-semibold text-red-800 dark:text-red-200">PDF to Images</span>
        </div>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
          Convert PDF Pages to Images
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Extract pages from PDF documents as PNG, JPEG, or WebP images
        </p>
      </div>
      <PdfConverter />
    </div>
  </ScrollReveal>

  <!-- Image Resizer Tool -->
  <ScrollReveal animation="fade-in-up" delay={800} id="image-resizer" class="py-12 bg-white dark:bg-gray-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2 bg-purple-100 dark:bg-purple-900/30 px-4 py-2 rounded-full mb-4">
          <Icon name="upload" size={20} class="text-purple-600 dark:text-purple-400" />
          <span class="text-sm font-semibold text-purple-800 dark:text-purple-200">Image Resizer</span>
        </div>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
          Resize and Compress Images
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Optimize images for web or print use directly in your browser
        </p>
      </div>
      <ImageResizer />
    </div>
  </ScrollReveal>
</MainLayout>
