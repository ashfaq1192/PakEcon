---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Page Not Found — HisaabKar.pk"
  description="The page you're looking for doesn't exist. Explore Pakistan economy news, gold prices, and financial guides on HisaabKar.pk."
>
  <section class="max-w-2xl mx-auto px-4 py-24 text-center">
    <div class="text-7xl font-black text-green-700 dark:text-green-400 mb-4">404</div>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-3">Page not found</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-10">
      This page doesn't exist or may have been moved.
      Explore live rates, economic news, and guides below.
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      <a href="/" class="flex flex-col items-center gap-2 p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-green-400 dark:hover:border-green-500 hover:shadow-md transition bg-white dark:bg-gray-800/40">
        <span class="text-2xl">🏠</span>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Home</span>
      </a>
      <a href="/rates/" class="flex flex-col items-center gap-2 p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-green-400 dark:hover:border-green-500 hover:shadow-md transition bg-white dark:bg-gray-800/40">
        <span class="text-2xl">📊</span>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Live Rates</span>
      </a>
      <a href="/blog/" class="flex flex-col items-center gap-2 p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-green-400 dark:hover:border-green-500 hover:shadow-md transition bg-white dark:bg-gray-800/40">
        <span class="text-2xl">📰</span>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Blog</span>
      </a>
      <a href="/tools/" class="flex flex-col items-center gap-2 p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-green-400 dark:hover:border-green-500 hover:shadow-md transition bg-white dark:bg-gray-800/40">
        <span class="text-2xl">🧮</span>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Tools</span>
      </a>
    </div>

    <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-green-700 text-white font-medium rounded-lg hover:bg-green-800 transition">
      ← Back to Homepage
    </a>
  </section>
</MainLayout>
