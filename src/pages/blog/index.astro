---
export const prerender = true;

import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const POSTS_PER_PAGE = 20;

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Substantive in-depth posts (featured at top)
const featuredPosts = posts
  .filter(p =>
    !p.id.startsWith('24k-') &&
    !p.id.startsWith('usd-pkr-rate-today') &&
    !p.id.startsWith('petrol-price-pakistan-today')
  )
  .slice(0, 3);

// Editorial posts only — exclude auto-generated rate micro-posts
const editorialPosts = posts.filter(p =>
  !p.id.startsWith('24k-') &&
  !p.id.startsWith('usd-pkr-rate-today') &&
  !p.id.startsWith('petrol-price-pakistan-today')
);

const totalPages = Math.ceil(editorialPosts.length / POSTS_PER_PAGE);
const pagePosts = editorialPosts.slice(0, POSTS_PER_PAGE);
const hasNextPage = totalPages > 1;

const categoryLabels: Record<string, string> = {
  market_insight: 'Market Insight',
  weekly_digest: 'Weekly Digest',
  budget_alert: 'Budget Alert',
  policy_update: 'Policy Update',
  news_roundup: 'Economy News',
};

const categoryColors: Record<string, string> = {
  market_insight: 'bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  weekly_digest: 'bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
  budget_alert: 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-300',
  policy_update: 'bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300',
  news_roundup: 'bg-teal-50 text-teal-700 dark:bg-teal-900/30 dark:text-teal-300',
};

const categoryGradients: Record<string, string> = {
  market_insight: 'from-blue-500 to-cyan-600',
  weekly_digest: 'from-purple-500 to-indigo-600',
  budget_alert: 'from-red-500 to-rose-600',
  policy_update: 'from-amber-500 to-orange-600',
  news_roundup: 'from-teal-500 to-emerald-600',
};

const categoryEmoji: Record<string, string> = {
  market_insight: '📊',
  weekly_digest: '📰',
  budget_alert: '🏛️',
  policy_update: '📋',
  news_roundup: '🌐',
};
---

<MainLayout
  title="Pakistan Economy Blog — HisaabKar.pk"
  description="In-depth economic analysis, market insights, and policy updates for Pakistan. AI-powered briefings on PKR exchange rates, inflation, gold prices, SBP policy, and FBR tax."
>
  <!-- Page hero -->
  <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav class="text-xs text-gray-500 mb-5 flex items-center gap-1">
        <a href="/" class="hover:text-green-400 transition">Home</a>
        <span>/</span>
        <span class="text-gray-400">Blog</span>
      </nav>
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-2">Pakistan Economy Blog</h1>
          <p class="text-gray-300 text-base max-w-lg">
            In-depth analysis on PKR rates, inflation, gold prices, FBR taxes, and SBP policy — sourced from official data, powered by AI.
          </p>
        </div>
        <div class="flex flex-col items-end gap-1 text-right shrink-0">
          <span class="text-xs bg-white/10 border border-white/20 px-3 py-1 rounded-full text-gray-300">
            📰 {posts.length} articles
          </span>
          <span class="text-xs text-gray-500">Updated daily</span>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">

    <!-- Featured / In-Depth Articles -->
    {featuredPosts.length > 0 && (
      <section class="mb-10">
        <div class="flex items-center gap-3 mb-5">
          <span class="inline-block bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full">In-Depth Analysis</span>
          <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {featuredPosts.map((post) => {
            const dateDisplay = post.data.pubDate.toLocaleDateString('en-PK', { year: 'numeric', month: 'short', day: 'numeric' });
            const grad = categoryGradients[post.data.category] ?? 'from-green-500 to-emerald-600';
            const emoji = categoryEmoji[post.data.category] ?? '📋';
            const catLabel = categoryLabels[post.data.category] ?? post.data.category;
            return (
              <article class="group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class={`h-16 bg-gradient-to-br ${grad} flex items-center gap-3 px-4`}>
                  <span class="text-xl">{emoji}</span>
                  <span class="text-xs font-semibold text-white/90 uppercase tracking-wider">{catLabel}</span>
                </div>
                <div class="p-4">
                  <h2 class="text-sm font-bold text-gray-900 dark:text-white mb-2 group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors leading-snug line-clamp-2">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h2>
                  <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2 mb-3 leading-relaxed">{post.data.summary}</p>
                  <div class="flex items-center justify-between">
                    <time class="text-xs text-gray-400">{dateDisplay}</time>
                    <a href={`/blog/${post.id}`} class="text-xs font-semibold text-green-600 dark:text-green-400 hover:underline">Read →</a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )}

    <!-- All Posts listing with category filter -->
    <section>
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-block bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full">All Updates</span>
        <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700"></div>
        <span class="text-xs text-gray-400">Page 1 of {totalPages}</span>
      </div>

      <!-- Category filter tabs -->
      <div class="flex gap-2 flex-wrap mb-6" id="cat-filter">
        <button data-cat="all" class="cat-btn active text-xs font-semibold px-3 py-1.5 rounded-full border transition-all bg-green-600 text-white border-green-600">All</button>
        {Object.entries(categoryLabels).map(([key, label]) => (
          <button data-cat={key} class={`cat-btn text-xs font-semibold px-3 py-1.5 rounded-full border transition-all bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 border-gray-200 dark:border-gray-700 hover:border-green-400 hover:text-green-700`}>
            {categoryEmoji[key]} {label}
          </button>
        ))}
      </div>

      {pagePosts.length === 0 ? (
        <div class="text-center py-20 text-gray-500">
          <p class="text-xl mb-2">First posts coming soon.</p>
          <p class="text-sm">Our AI agent publishes fresh economic analysis daily.</p>
        </div>
      ) : (
        <div class="space-y-3" id="posts-list">
          {pagePosts.map((post) => {
            const dateDisplay = post.data.pubDate.toLocaleDateString('en-PK', {
              year: 'numeric', month: 'short', day: 'numeric',
            });
            const catColor = categoryColors[post.data.category] ?? 'bg-gray-100 text-gray-600';
            const catLabel = categoryLabels[post.data.category] ?? post.data.category;
            return (
              <article
                class="border border-gray-200 dark:border-gray-700 rounded-xl p-4 hover:shadow-md hover:border-green-300 dark:hover:border-green-600 transition bg-white dark:bg-gray-800/40 flex items-start gap-4 post-card"
                data-cat={post.data.category}
              >
                <div class={`h-10 w-10 rounded-lg bg-gradient-to-br ${categoryGradients[post.data.category] ?? 'from-gray-400 to-gray-500'} flex items-center justify-center shrink-0 text-lg`}>
                  {categoryEmoji[post.data.category] ?? '📋'}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1 flex-wrap">
                    <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full ${catColor}`}>
                      {catLabel}
                    </span>
                    {post.data.delta !== 0 && (
                      <span class={`text-xs font-medium ${post.data.delta > 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400'}`}>
                        {post.data.delta > 0 ? '▲' : '▼'} {Math.abs(post.data.delta).toFixed(2)}%
                      </span>
                    )}
                    <time class="text-xs text-gray-400 ml-auto">{dateDisplay}</time>
                  </div>
                  <h2 class="text-sm font-bold text-gray-900 dark:text-white leading-snug">
                    <a href={`/blog/${post.id}`} class="hover:text-green-700 dark:hover:text-green-400 transition">
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="text-gray-500 dark:text-gray-400 text-xs leading-relaxed mt-1 line-clamp-1">{post.data.summary}</p>
                </div>
                <a href={`/blog/${post.id}`} class="shrink-0 text-xs font-semibold text-green-700 dark:text-green-400 hover:underline whitespace-nowrap self-center">
                  Read →
                </a>
              </article>
            );
          })}
        </div>
      )}
    </section>

    <!-- Pagination controls -->
    {hasNextPage && (
      <nav class="mt-8 flex items-center justify-between" aria-label="Pagination">
        <span class="text-sm text-gray-500 dark:text-gray-400">Page 1 of {totalPages}</span>
        <a
          href="/blog/page/2/"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-green-700 text-white text-sm font-medium rounded-xl hover:bg-green-800 transition"
        >
          Next page →
        </a>
      </nav>
    )}
  </div>

  <script>
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
    const cards = document.querySelectorAll<HTMLElement>('.post-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.cat ?? 'all';

        filterBtns.forEach(b => {
          b.classList.remove('bg-green-600', 'text-white', 'border-green-600', 'active');
          b.classList.add('bg-white', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-400', 'border-gray-200', 'dark:border-gray-700');
        });
        btn.classList.remove('bg-white', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-400', 'border-gray-200', 'dark:border-gray-700');
        btn.classList.add('bg-green-600', 'text-white', 'border-green-600', 'active');

        cards.forEach(card => {
          if (cat === 'all' || card.dataset.cat === cat) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</MainLayout>
