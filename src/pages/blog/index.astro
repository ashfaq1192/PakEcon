---
export const prerender = true;

import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categoryLabels: Record<string, string> = {
  market_insight: 'Market Insight',
  weekly_digest: 'Weekly Digest',
  budget_alert: 'Budget Alert',
  policy_update: 'Policy Update',
};

const categoryColors: Record<string, string> = {
  market_insight: 'bg-blue-50 text-blue-700',
  weekly_digest: 'bg-purple-50 text-purple-700',
  budget_alert: 'bg-red-50 text-red-700',
  policy_update: 'bg-amber-50 text-amber-700',
};
---

<MainLayout
  title="Pakistan Economy Blog — HisaabKar.pk"
  description="Daily economic analysis, market insights, and policy updates for Pakistan. AI-powered briefings on PKR exchange rates, inflation, gold prices, and more."
>
  <section class="max-w-4xl mx-auto px-4 py-10">
    <header class="mb-10">
      <h1 class="text-4xl font-bold text-gray-900 mb-3">Pakistan Economy Blog</h1>
      <p class="text-lg text-gray-600">
        Daily AI-generated analysis on PKR exchange rates, inflation, commodity prices, and policy updates.
        All data sourced from SBP, PBS, and OGRA.
      </p>
    </header>

    {posts.length === 0 ? (
      <div class="text-center py-20 text-gray-500">
        <p class="text-xl mb-2">First posts coming soon.</p>
        <p class="text-sm">Our AI agent publishes fresh economic analysis daily.</p>
      </div>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => {
          const dateDisplay = post.data.pubDate.toLocaleDateString('en-PK', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          const catColor = categoryColors[post.data.category] ?? 'bg-gray-100 text-gray-600';
          const catLabel = categoryLabels[post.data.category] ?? post.data.category;
          return (
            <article class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition bg-white">
              <div class="flex items-center gap-3 mb-3">
                <span class={`text-xs font-semibold uppercase tracking-widest px-2 py-1 rounded ${catColor}`}>
                  {catLabel}
                </span>
                {post.data.delta !== 0 && (
                  <span class={`text-sm font-medium ${post.data.delta > 0 ? 'text-red-600' : 'text-green-600'}`}>
                    {post.data.delta > 0 ? '▲' : '▼'} {Math.abs(post.data.delta).toFixed(2)}%
                  </span>
                )}
                <time class="text-xs text-gray-400 ml-auto">{dateDisplay}</time>
              </div>
              <h2 class="text-xl font-bold text-gray-900 mb-2">
                <a href={`/blog/${post.slug}`} class="hover:text-green-700 transition">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-gray-600 text-sm leading-relaxed">{post.data.summary}</p>
              <a
                href={`/blog/${post.slug}`}
                class="inline-block mt-4 text-sm font-medium text-green-700 hover:underline"
              >
                Read analysis →
              </a>
            </article>
          );
        })}
      </div>
    )}
  </section>
</MainLayout>
