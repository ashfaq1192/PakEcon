---
export const prerender = true;

import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const pubDateISO = entry.data.pubDate.toISOString();
const pubDateDisplay = entry.data.pubDate.toLocaleDateString('en-PK', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const schemaArticle = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.summary,
  datePublished: pubDateISO,
  author: {
    '@type': 'Person',
    name: 'Muhammad',
    jobTitle: 'Economic Analyst',
    description: 'M.Phil Economics, B.Com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'HisaabKar.pk',
    url: 'https://hisaabkar.pk',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://hisaabkar.pk/blog/${entry.slug}`,
  },
});
---

<MainLayout title={entry.data.title} description={entry.data.summary}>
  <script type="application/ld+json" set:html={schemaArticle} />

  <article class="max-w-3xl mx-auto px-4 py-10">
    <header class="mb-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-green-700 bg-green-50 px-2 py-1 rounded">
        {entry.data.category.replace(/_/g, ' ')}
      </span>
      <h1 class="text-3xl font-bold mt-3 mb-2 text-gray-900">{entry.data.title}</h1>
      <p class="text-gray-500 text-sm">
        Published <time datetime={pubDateISO}>{pubDateDisplay}</time>
        {entry.data.delta !== 0 && (
          <span class={`ml-3 font-medium ${entry.data.delta > 0 ? 'text-red-600' : 'text-green-600'}`}>
            {entry.data.delta > 0 ? '▲' : '▼'} {Math.abs(entry.data.delta).toFixed(2)}%
          </span>
        )}
      </p>
      <p class="mt-3 text-lg text-gray-700">{entry.data.summary}</p>
    </header>

    <div class="prose prose-green max-w-none">
      <Content />
    </div>

    <footer class="mt-10 pt-6 border-t border-gray-200 text-sm text-gray-500">
      <p>
        <strong>Source:</strong>{' '}
        <a href={entry.data.source} target="_blank" rel="noopener noreferrer" class="text-green-700 underline">
          {entry.data.source}
        </a>
      </p>
      <p class="mt-2 italic">
        Information provided is for educational purposes and based on public data. Not financial advice.
      </p>
    </footer>
  </article>
</MainLayout>
