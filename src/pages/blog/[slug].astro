---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pubDateISO = entry.data.pubDate.toISOString();
const pubDateDisplay = entry.data.pubDate.toLocaleDateString('en-PK', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const isNewsRoundup = entry.data.category === 'news_roundup';
const pageUrl = `https://hisaabkar.pk/blog/${entry.id}`;

// ── Author ───────────────────────────────────────────────────────────────────
const author = (entry.data as any).author ?? 'HisaabKar Editorial';

// ── FAQ extraction — parse "## Frequently Asked Questions" section ────────────
function extractFaqs(body: string): Array<{ question: string; answer: string }> {
  const faqSection = body.split(/^##\s+Frequently Asked Questions/im)[1];
  if (!faqSection) return [];

  const faqs: Array<{ question: string; answer: string }> = [];

  // Pattern 1: ### H3 question followed by paragraph answer
  const h3Pattern = /###\s+(.+?)\n([\s\S]+?)(?=\n###|\n##|$)/g;
  let match: RegExpExecArray | null;
  while ((match = h3Pattern.exec(faqSection)) !== null) {
    const question = match[1].trim();
    const answer = match[2].replace(/\*\*/g, '').replace(/\n+/g, ' ').trim().slice(0, 300);
    if (question && answer) faqs.push({ question, answer });
  }

  // Pattern 2: **Q: question** / A: answer  or  **question**\nanswer
  if (faqs.length === 0) {
    const boldPattern = /\*\*(?:Q:\s*)?(.+?)\*\*\n+(?:A:\s*)?([\s\S]+?)(?=\n\*\*|\n##|$)/g;
    while ((match = boldPattern.exec(faqSection)) !== null) {
      const question = match[1].trim();
      const answer = match[2].replace(/\*\*/g, '').replace(/\n+/g, ' ').trim().slice(0, 300);
      if (question && answer) faqs.push({ question, answer });
    }
  }

  return faqs.slice(0, 6); // cap at 6 FAQ items
}

const faqs = extractFaqs(entry.body ?? '');

// ── JSON-LD schema ────────────────────────────────────────────────────────────
const authorSchema = {
  '@type': 'Person',
  name: author,
  jobTitle: 'Economic Analyst',
  description: 'M.Phil Economics, B.Com — Pakistan Finance Specialist',
  url: 'https://hisaabkar.pk/about',
};

const publisherSchema = {
  '@type': 'Organization',
  name: 'HisaabKar.pk',
  url: 'https://hisaabkar.pk',
  logo: { '@type': 'ImageObject', url: 'https://hisaabkar.pk/logo.png' },
};

// NewsArticle for news_roundup, Article for everything else
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': isNewsRoundup ? 'NewsArticle' : 'Article',
  headline: entry.data.title,
  description: entry.data.summary,
  datePublished: pubDateISO,
  dateModified: pubDateISO,
  author: authorSchema,
  publisher: publisherSchema,
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  about: { '@type': 'Thing', name: 'Pakistan Economy' },
  inLanguage: 'en-US',
  isAccessibleForFree: true,
  keywords: 'Pakistan economy, finance Pakistan, PKR, SBP, inflation Pakistan',
  ...(isNewsRoundup && {
    articleSection: 'Economy News',
    // newsArticle-specific: mark as opinion/analysis not breaking news
    backstory: 'Daily economic news analysis for Pakistani readers.',
  }),
};

// FAQPage schema — only emit if we extracted FAQ items
const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;

// BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hisaabkar.pk/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://hisaabkar.pk/blog/' },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
  ],
};

const articleSchemaJson = JSON.stringify(articleSchema);
const faqSchemaJson = faqSchema ? JSON.stringify(faqSchema) : null;
const breadcrumbSchemaJson = JSON.stringify(breadcrumbSchema);

// ── Related posts — same category, exclude current ───────────────────────────
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.id !== entry.id && p.data.category === entry.data.category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// ── Category display ──────────────────────────────────────────────────────────
const categoryLabels: Record<string, string> = {
  market_insight: 'Market Insight',
  weekly_digest: 'Weekly Digest',
  budget_alert: 'Budget Alert',
  policy_update: 'Policy Update',
  news_roundup: 'Economy News',
};
const categoryColors: Record<string, string> = {
  market_insight: 'bg-blue-50 text-blue-700',
  weekly_digest: 'bg-purple-50 text-purple-700',
  budget_alert: 'bg-red-50 text-red-700',
  policy_update: 'bg-amber-50 text-amber-700',
  news_roundup: 'bg-teal-50 text-teal-700',
};
const catLabel = categoryLabels[entry.data.category] ?? entry.data.category.replace(/_/g, ' ');
const catColor = categoryColors[entry.data.category] ?? 'bg-gray-100 text-gray-600';
---

<MainLayout title={entry.data.title} description={entry.data.summary} type="Article" schemaData={{ title: entry.data.title, description: entry.data.summary, datePublished: pubDateISO }}>
  <script type="application/ld+json" set:html={articleSchemaJson} />
  {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
  <script type="application/ld+json" set:html={breadcrumbSchemaJson} />

  <article class="max-w-3xl mx-auto px-4 py-10">
    <header class="mb-8">
      <!-- Breadcrumb nav -->
      <nav class="text-xs text-gray-500 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-green-700">Home</a>
        <span class="mx-1">/</span>
        <a href="/blog/" class="hover:text-green-700">Blog</a>
        <span class="mx-1">/</span>
        <span class="text-gray-400 line-clamp-1">{entry.data.title}</span>
      </nav>
      <span class={`text-xs font-semibold uppercase tracking-widest px-2 py-1 rounded ${catColor}`}>
        {catLabel}
      </span>
      <h1 class="text-3xl font-bold mt-3 mb-2 text-gray-900 dark:text-white">{entry.data.title}</h1>

      <!-- Author + date byline -->
      <div class="flex items-center gap-3 mt-2 mb-3">
        <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-700 font-bold text-sm">
          {author.charAt(0).toUpperCase()}
        </div>
        <div class="text-sm text-gray-600 dark:text-gray-400">
          <span class="font-medium text-gray-800 dark:text-gray-200">{author}</span>
          <span class="mx-1">·</span>
          <time datetime={pubDateISO}>{pubDateDisplay}</time>
          {entry.data.delta !== 0 && (
            <span class={`ml-3 font-medium ${entry.data.delta > 0 ? 'text-red-600' : 'text-green-600'}`}>
              {entry.data.delta > 0 ? '▲' : '▼'} {Math.abs(entry.data.delta).toFixed(2)}%
            </span>
          )}
        </div>
      </div>

      <p class="mt-3 text-lg text-gray-700 dark:text-gray-300">{entry.data.summary}</p>
    </header>

    <div class="prose prose-lg prose-green max-w-none dark:prose-invert
      prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-gray-200 dark:prose-h2:border-gray-700 prose-h2:pb-2
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-gray-700 dark:prose-p:text-gray-300 prose-p:leading-relaxed
      prose-a:text-green-600 dark:prose-a:text-green-400 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
      prose-strong:text-gray-900 dark:prose-strong:text-white
      prose-blockquote:border-l-4 prose-blockquote:border-green-500 prose-blockquote:bg-green-50 dark:prose-blockquote:bg-green-900/20 prose-blockquote:px-4 prose-blockquote:py-1 prose-blockquote:rounded-r-lg prose-blockquote:not-italic
      prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-code:text-green-700 dark:prose-code:text-green-400 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
      prose-table:text-sm prose-thead:bg-gray-100 dark:prose-thead:bg-gray-800 prose-th:px-4 prose-th:py-2 prose-td:px-4 prose-td:py-2
      prose-ul:space-y-1 prose-ol:space-y-1
      prose-li:text-gray-700 dark:prose-li:text-gray-300
      prose-hr:border-gray-200 dark:prose-hr:border-gray-700">
      <Content />
    </div>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <aside class="mt-10">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Related Articles</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-green-300 dark:hover:border-green-600 hover:shadow-md transition bg-white dark:bg-gray-800/40"
            >
              <time class="text-xs text-gray-400">
                {post.data.pubDate.toLocaleDateString('en-PK', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
              <p class="mt-1 text-sm font-semibold text-gray-800 dark:text-gray-200 group-hover:text-green-700 dark:group-hover:text-green-400 line-clamp-2 leading-snug">
                {post.data.title}
              </p>
            </a>
          ))}
        </div>
      </aside>
    )}

    <!-- Author bio card -->
    <div class="mt-10 p-4 border border-gray-200 dark:border-gray-700 rounded-xl bg-gray-50 dark:bg-gray-800/50 flex gap-4 items-start">
      <div class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/40 flex items-center justify-center text-green-700 dark:text-green-400 font-bold text-base shrink-0">
        {author.charAt(0).toUpperCase()}
      </div>
      <div>
        <p class="font-semibold text-gray-900 dark:text-white text-sm">{author}</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">M.Phil Economics, B.Com · Pakistan Finance Specialist</p>
        <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">
          Covering Pakistani economy, monetary policy, and financial markets for everyday readers.
        </p>
      </div>
    </div>

    <footer class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-700 text-sm text-gray-500">
      <p>
        <strong>Source:</strong>{' '}
        <a href={entry.data.source} target="_blank" rel="noopener noreferrer" class="text-green-700 dark:text-green-400 underline">
          {entry.data.source}
        </a>
      </p>
      <p class="mt-2 italic">
        Information provided is for educational purposes and based on public data. Not financial advice.
      </p>
    </footer>
  </article>
</MainLayout>
