---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import RemittanceCalculator from '../../components/tools/RemittanceCalculator';

const title = 'Pakistan Remittance Calculator — Send Money to Pakistan (Live Rates)';
const description =
  'Calculate how much PKR your family receives when you send GBP, EUR, USD, AED, SAR, CAD, AUD, or RON using live SBP interbank exchange rates.';
const pageUrl = 'https://hisaabkar.pk/tools/remittance-calculator';
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: title,
    description,
    url: pageUrl,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web, Android, iOS',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'PKR' },
    featureList: 'Live SBP interbank rates, USD GBP EUR AED SAR CAD AUD RON, PKR family receives calculation, All major remittance corridors',
    inLanguage: 'en-US',
    publisher: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hisaabkar.pk' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://hisaabkar.pk/tools' },
      { '@type': 'ListItem', position: 3, name: 'Remittance Calculator', item: pageUrl },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I send money to Pakistan from the USA?',
        acceptedAnswer: { '@type': 'Answer', text: 'The best ways to send money to Pakistan from the USA in 2026: (1) Wise — closest to interbank rate, low flat fee, fast; (2) Remitly — competitive rates, bank or mobile wallet delivery; (3) ACE Money Transfer — good for cash pickup; (4) Bank wire (HBL, MCB, UBL USA branch) — slow but reliable for large amounts; (5) Roshan Digital Account transfer — if recipient has an RDA, transfers settle in hours. For amounts under $2,000, Wise or Remitly offer the best rates. For larger amounts, compare bank wire vs Wise.' },
      },
      {
        '@type': 'Question',
        name: 'Does Pakistan tax remittances received from abroad?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Remittances received from overseas are not taxable income in Pakistan. The State Bank of Pakistan actively encourages remittances through official banking channels. However, if you receive large amounts regularly (above USD 10,000/month consistently), SBP may request source-of-funds documentation. Remittances through unofficial hawala channels are illegal and unprotected.' },
      },
      {
        '@type': 'Question',
        name: 'What is the Roshan Digital Account for overseas Pakistanis?',
        acceptedAnswer: { '@type': 'Answer', text: 'The Roshan Digital Account (RDA) is an SBP initiative allowing overseas Pakistanis to open Pakistani bank accounts remotely (via mobile app, no branch visit needed). It supports PKR and USD accounts, and allows investment in National Savings (Naya Pakistan Certificates at 8.25% USD yield), property, and stocks — all from abroad. Available through HBL, MCB, UBL, ABL, Meezan Bank, and others. Opens in 24-48 hours online.' },
      },
      {
        '@type': 'Question',
        name: 'What is the best way to send large amounts to Pakistan?',
        acceptedAnswer: { '@type': 'Answer', text: 'For amounts above $5,000: (1) Compare Wise Business vs bank wire — Wise still competitive for large amounts; (2) Use your bank\'s international wire to a Pakistani bank account (HBL, MCB, UBL) — typically 1-3 business days; (3) Roshan Digital Account transfers are fast and official; (4) Avoid money transfer operators for large amounts as their spread becomes expensive. Always use official channels — hawala is illegal and provides no protection.' },
      },
    ],
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-500 mb-6">
      <a href="/" class="hover:text-green-700">Home</a>
      <span class="mx-1">/</span>
      <a href="/tools" class="hover:text-green-700">Tools</a>
      <span class="mx-1">/</span>
      <span>Remittance Calculator</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">{title}</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6 text-sm">
      Calculate how much Pakistani Rupees your family will receive based on live SBP interbank rates.
      Supports all major remittance corridors including USD (USA), GBP (UK), AED (UAE), SAR (Saudi Arabia), and EUR (Europe).
    </p>

    <RemittanceCalculator client:load />

    <!-- US diaspora CTA -->
    <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
      <p class="text-sm text-blue-800 font-medium mb-1">Sending from the USA?</p>
      <p class="text-xs text-blue-700 mb-2">Compare Wise vs Remitly vs Western Union to see which gives your family the most PKR.</p>
      <a href="/us/send-money-to-pakistan-from-usa/" class="text-xs font-semibold text-blue-700 underline hover:text-blue-900">
        Best way to send money from USA to Pakistan →
      </a>
    </div>

    <!-- FAQ / SEO content -->
    <div class="mt-12 prose prose-sm max-w-none text-gray-700 dark:text-gray-300">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mt-8 mb-3">Frequently Asked Questions</h2>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">How do I send money to Pakistan from the USA?</h3>
      <p>Best options: Wise (closest to interbank rate), Remitly (competitive + mobile wallet), ACE Money Transfer (cash pickup), bank wire (HBL/MCB/UBL for large amounts), or Roshan Digital Account transfer. For under $2,000 — Wise or Remitly. For larger — compare bank wire rates.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">Are remittances taxable in Pakistan?</h3>
      <p>No. Remittances received in Pakistan are not taxable income. SBP actively encourages official channel remittances. Hawala transfers are illegal and unprotected.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">What is a Roshan Digital Account?</h3>
      <p>An SBP scheme allowing overseas Pakistanis to open PKR/USD accounts online (no branch visit). Supports National Savings at 8.25% USD yield, property finance (Roshan Apna Ghar), and stock investments. Available at HBL, MCB, UBL, Meezan Bank.</p>
    </div>
  </div>
</MainLayout>
