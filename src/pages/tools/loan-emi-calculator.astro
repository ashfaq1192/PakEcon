---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import LoanEmiCalculator from '../../components/tools/LoanEmiCalculator';

const title = 'Pakistan Loan EMI Calculator 2026 — Home, Car, Personal (Conventional & Islamic)';
const description =
  'Calculate monthly EMI or installment for home, car, personal, or business loans in Pakistan. Supports conventional interest-based and Islamic/Murabaha profit-based financing with amortization schedule and prepayment simulation.';
const pageUrl = 'https://hisaabkar.pk/tools/loan-emi-calculator';
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: title,
    description,
    url: pageUrl,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web, Android, iOS',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'PKR' },
    featureList: 'Conventional and Islamic Murabaha modes, Amortization schedule, Prepayment simulation, Home car personal business loans',
    inLanguage: 'en-PK',
    publisher: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hisaabkar.pk' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://hisaabkar.pk/tools' },
      { '@type': 'ListItem', position: 3, name: 'Loan EMI Calculator', item: pageUrl },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the current SBP policy rate in Pakistan 2026?',
        acceptedAnswer: { '@type': 'Answer', text: 'The State Bank of Pakistan (SBP) policy rate in 2026 is 12% (as of May 2026), down from a peak of 22% in 2023. SBP has been cutting rates as inflation has declined from its 2023 peak. Bank lending rates for home loans are typically KIBOR + 1-3%, which currently translates to approximately 13-16% per annum for conventional loans.' },
      },
      {
        '@type': 'Question',
        name: 'What is KIBOR and how does it affect my loan rate?',
        acceptedAnswer: { '@type': 'Answer', text: 'KIBOR (Karachi Interbank Offered Rate) is the benchmark lending rate between Pakistani banks. Most commercial loans in Pakistan are priced as KIBOR plus a spread (e.g., KIBOR + 2%). As SBP cuts the policy rate, KIBOR falls, and your floating-rate loan EMI decreases. Check sbp.org.pk for the current KIBOR rate.' },
      },
      {
        '@type': 'Question',
        name: 'How is EMI calculated in Pakistan?',
        acceptedAnswer: { '@type': 'Answer', text: 'EMI (Equated Monthly Installment) formula: EMI = P × r × (1+r)^n / ((1+r)^n - 1), where P = principal loan amount, r = monthly interest rate (annual rate ÷ 12), n = loan tenure in months. For a PKR 5 million home loan at 15% per annum for 20 years: r = 1.25%, n = 240 months → EMI ≈ PKR 65,818/month.' },
      },
      {
        '@type': 'Question',
        name: 'What is the difference between conventional and Islamic (Murabaha) loan?',
        acceptedAnswer: { '@type': 'Answer', text: 'Conventional loans charge interest (riba) which is prohibited in Islam. Islamic Murabaha is a cost-plus-profit structure: the bank buys the asset and sells it to you at a fixed profit margin. The monthly payment amount is similar, but the legal structure is different. Diminishing Musharakah (used for home finance) means you gradually buy the bank\'s share in the property. Islamic banks in Pakistan offer these under Shariah supervision.' },
      },
      {
        '@type': 'Question',
        name: 'Can overseas Pakistanis get a home loan in Pakistan?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. The SBP launched the Roshan Apna Ghar scheme specifically for Non-Resident Pakistanis (NRPs). It offers PKR and USD-denominated home financing through partner banks (HBL, MCB, UBL, ABL, Meezan). Repayments can be made from your Roshan Digital Account. Visit sbp.org.pk/RDAC/Ghar.html for details.' },
      },
    ],
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-500 mb-6">
      <a href="/" class="hover:text-green-700">Home</a>
      <span class="mx-1">/</span>
      <a href="/tools" class="hover:text-green-700">Tools</a>
      <span class="mx-1">/</span>
      <span>Loan EMI Calculator</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">{title}</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6 text-sm">
      Calculate your monthly installment for any type of loan or Islamic financing.
      Includes a 12-month amortization schedule and lump-sum prepayment simulation.
    </p>

    <LoanEmiCalculator client:load />

    <div class="mt-8 p-4 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-800">
      <strong>Disclaimer:</strong> This calculator provides estimates for informational
      purposes only. Actual loan terms, interest/profit rates, and processing fees vary by
      institution. For Islamic financing, consult your bank's Shariah board for product-specific
      terms. HisaabKar.pk is not a licensed financial advisor and does not provide lending services.
    </div>

    <!-- FAQ / SEO content -->
    <div class="mt-12 prose prose-sm max-w-none text-gray-700 dark:text-gray-300">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mt-8 mb-3">Frequently Asked Questions</h2>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">What is the SBP policy rate in 2026?</h3>
      <p>12% as of May 2026, reduced from a peak of 22% in 2023. Bank home loan rates are typically KIBOR + 1–3%, translating to roughly 13–16% per annum.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">How is EMI calculated?</h3>
      <p>EMI = P × r × (1+r)^n / ((1+r)^n − 1). For a PKR 5M home loan at 15% for 20 years: EMI ≈ PKR 65,818/month, total payment ≈ PKR 15.8M including interest.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">What is Islamic Murabaha financing?</h3>
      <p>Murabaha is a cost-plus-profit structure where the bank buys the asset and sells it to you at a disclosed markup. Monthly payments are similar to conventional EMI but the structure avoids interest (riba). Used by all Islamic banks in Pakistan (Meezan, Dubai Islamic, Bank Islami, etc.).</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">Can overseas Pakistanis get a home loan in Pakistan?</h3>
      <p>Yes — SBP's Roshan Apna Ghar scheme offers home financing in PKR and USD for NRPs. Repayments from your Roshan Digital Account. Available through HBL, MCB, UBL, ABL, and Meezan Bank.</p>
    </div>
  </div>
</MainLayout>
