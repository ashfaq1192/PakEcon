---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import EobiCalculator from '../../components/tools/EobiCalculator';

const title = 'Pakistan EOBI Pension & Provident Fund Calculator 2026';
const description =
  'Calculate your expected EOBI pension and Provident Fund (PF) corpus at retirement age 60 based on current salary and years of service.';
const pageUrl = 'https://hisaabkar.pk/tools/eobi-calculator';
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: title,
    description,
    url: pageUrl,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web, Android, iOS',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'PKR' },
    featureList: 'EOBI pension estimate, Provident Fund corpus at retirement, Salary and service years input, PKR 10000 base EOBI rate 2026',
    inLanguage: 'en-PK',
    publisher: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hisaabkar.pk' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://hisaabkar.pk/tools' },
      { '@type': 'ListItem', position: 3, name: 'EOBI & PF Calculator', item: pageUrl },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the EOBI pension amount in Pakistan 2026?',
        acceptedAnswer: { '@type': 'Answer', text: 'The EOBI (Employees Old-Age Benefits Institution) minimum pension is PKR 10,000 per month as of 2026, increased from PKR 8,500 in the previous year. This is the minimum guaranteed monthly pension for all registered EOBI beneficiaries who have completed the minimum contribution period (15 years of service with registered employer). The pension continues for life after age 60.' },
      },
      {
        '@type': 'Question',
        name: 'How is EOBI contribution calculated in Pakistan?',
        acceptedAnswer: { '@type': 'Answer', text: 'EOBI contribution is 6% of the minimum wage: Employee contributes 1% and Employer contributes 5%. In 2026, the minimum wage is PKR 37,000/month, so total EOBI contribution = PKR 2,220/month (employee PKR 370, employer PKR 1,850). The contribution is based on the minimum wage, not the employee\'s actual salary, so even high-earners contribute the same fixed amount.' },
      },
      {
        '@type': 'Question',
        name: 'Who is eligible for EOBI pension in Pakistan?',
        acceptedAnswer: { '@type': 'Answer', text: 'EOBI pension eligibility requires: (1) minimum 15 years of contribution (Insured Persons); (2) retirement at age 60 (men) or 55 (women); (3) the employer must have been registered with EOBI. Employees of registered establishments (typically those with 5+ workers) are automatically enrolled. Voluntary membership is available for self-employed individuals.' },
      },
      {
        '@type': 'Question',
        name: 'What is the difference between EOBI and Provident Fund in Pakistan?',
        acceptedAnswer: { '@type': 'Answer', text: 'EOBI is a government-run social insurance scheme providing a fixed monthly pension for life after retirement. Provident Fund (PF) is a savings scheme where both employee and employer contribute a percentage of salary monthly, and the accumulated corpus (with profit) is paid as a lump sum on retirement, resignation, or death. PF is managed by the employer or a trust; EOBI is managed by the federal government.' },
      },
    ],
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-500 mb-6">
      <a href="/" class="hover:text-green-700">Home</a>
      <span class="mx-1">/</span>
      <a href="/tools" class="hover:text-green-700">Tools</a>
      <span class="mx-1">/</span>
      <span>EOBI & PF Calculator</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">{title}</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6 text-sm">
      Estimate your EOBI monthly pension and Provident Fund corpus at retirement.
      Based on current EOBI minimum pension of PKR 10,000/month (2026).
    </p>

    <EobiCalculator client:load />

    <div class="mt-8 p-4 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-800">
      <strong>Disclaimer:</strong> EOBI pension amount is based on current notified rate of PKR 10,000/month
      effective 2026 and is subject to revision by the EOBI Board of Trustees. PF calculations assume
      constant salary and growth rate. Actual PF returns depend on fund performance. This tool does not
      account for pension eligibility criteria (minimum years of contribution). Consult your HR
      department or a financial planner for personalized advice.
    </div>

    <!-- FAQ / SEO content -->
    <div class="mt-12 prose prose-sm max-w-none text-gray-700 dark:text-gray-300">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mt-8 mb-3">Frequently Asked Questions</h2>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">What is the EOBI pension amount in 2026?</h3>
      <p>PKR 10,000/month minimum, paid for life after age 60 (men) or 55 (women), after completing 15 years of contributions.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">How is EOBI contribution calculated?</h3>
      <p>6% of minimum wage (PKR 37,000 in 2026): employee pays 1% (PKR 370), employer pays 5% (PKR 1,850). Total = PKR 2,220/month regardless of actual salary.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">What is the difference between EOBI and PF?</h3>
      <p>EOBI = government lifetime monthly pension. PF = employer-managed savings fund paid as lump sum. Both complement each other for retirement planning.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">Who is eligible for EOBI?</h3>
      <p>Employees of EOBI-registered establishments (typically 5+ workers) with 15+ years of contributions, retiring at 60 (men) / 55 (women). Voluntary membership available for self-employed.</p>
    </div>
  </div>
</MainLayout>
