---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import EobiCalculator from '../../components/tools/EobiCalculator';

const title = 'Pakistan EOBI Pension & Provident Fund Calculator 2026';
const description =
  'Calculate your expected EOBI pension and Provident Fund (PF) corpus at retirement age 60 based on current salary and years of service.';
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: 'https://hisaabkar.pk/tools/eobi-calculator',
    inLanguage: 'en-PK',
    publisher: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">{title}</h1>
    <p class="text-gray-600 mb-6 text-sm">
      Estimate your EOBI monthly pension and Provident Fund corpus at retirement.
      Based on current EOBI minimum pension of PKR 10,000/month (2026).
    </p>

    <EobiCalculator client:load />

    <div class="mt-8 p-4 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-800">
      <strong>Disclaimer:</strong> EOBI pension amount is based on current notified rate of PKR 10,000/month
      effective 2026 and is subject to revision by the EOBI Board of Trustees. PF calculations assume
      constant salary and growth rate. Actual PF returns depend on fund performance. This tool does not
      account for pension eligibility criteria (minimum years of contribution). Consult your HR
      department or a financial planner for personalized advice.
    </div>
  </div>
</MainLayout>
