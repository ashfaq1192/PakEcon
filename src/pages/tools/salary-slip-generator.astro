---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import SalarySlipGenerator from '../../components/tools/SalarySlipGenerator';

const title = 'Free Salary Slip Generator Pakistan 2026 — Download PDF';
const description =
  'Generate professional salary slips for Pakistan with automatic FBR 2026 income tax calculation and PDF download. Supports custom earnings, deductions, and template saving.';
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: 'https://hisaabkar.pk/tools/salary-slip-generator',
    inLanguage: 'en-PK',
    publisher: {
      '@type': 'Organization',
      name: 'HisaabKar.pk',
      url: 'https://hisaabkar.pk',
    },
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">{title}</h1>
    <p class="text-gray-600 mb-6 text-sm">
      Create and download professional salary slips in PDF format. Income Tax Advance is
      auto-calculated from FBR 2026 slabs. All data stays in your browser — nothing is uploaded.
    </p>

    <SalarySlipGenerator client:load />
  </div>
</MainLayout>
