---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import CurrencyConverter from '../../components/tools/CurrencyConverter';

const title = 'Live PKR Currency Converter — SBP Interbank Rates 2026';
const description =
  'Convert Pakistani Rupee (PKR) to USD, EUR, GBP, AED, SAR, CAD, AUD, CNY, JPY, RON using live SBP interbank rates. Includes 30-day trend chart.';
const pageUrl = 'https://hisaabkar.pk/tools/currency-converter';
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: title,
    description,
    url: pageUrl,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web, Android, iOS',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'PKR' },
    featureList: 'Live SBP interbank rates, 10 currency pairs, 30-day trend chart, USD EUR GBP AED SAR CAD AUD CNY JPY RON',
    inLanguage: 'en-PK',
    publisher: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hisaabkar.pk' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://hisaabkar.pk/tools' },
      { '@type': 'ListItem', position: 3, name: 'Currency Converter', item: pageUrl },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the USD to PKR rate today?',
        acceptedAnswer: { '@type': 'Answer', text: 'The live USD to PKR interbank rate is shown in the converter above, sourced from the State Bank of Pakistan (SBP). The SBP interbank rate is the official bank-to-bank rate. Open market rates at currency exchange shops typically differ by PKR 1–3. For the best rate on remittances to Pakistan, compare Wise, Remitly, and your bank\'s official rate against the SBP benchmark.' },
      },
      {
        '@type': 'Question',
        name: 'What is the difference between SBP interbank rate and open market rate?',
        acceptedAnswer: { '@type': 'Answer', text: 'The SBP interbank rate is the official rate for transactions between banks, set by market forces under SBP oversight. The open market rate applies to currency exchange shops (sarafa) and can differ by PKR 1–5 depending on market conditions. Remittance services like Wise and Remitly offer rates close to the interbank rate, which is why they are often cheaper than traditional money transfer operators.' },
      },
      {
        '@type': 'Question',
        name: 'What is the AED to PKR rate today?',
        acceptedAnswer: { '@type': 'Answer', text: 'The live AED (UAE Dirham) to PKR rate is shown in the currency converter above. The AED/PKR rate is significant for Pakistani workers in the UAE — one of the largest remittance corridors to Pakistan. The AED is pegged to USD at 3.6725, so AED/PKR moves closely with USD/PKR.' },
      },
      {
        '@type': 'Question',
        name: 'What is the SAR to PKR rate today?',
        acceptedAnswer: { '@type': 'Answer', text: 'The live SAR (Saudi Riyal) to PKR rate is shown in the converter above. Saudi Arabia is the single largest source of remittances to Pakistan, making SAR/PKR one of the most-watched currency pairs for Pakistani families. The SAR is pegged to USD at 3.75, so SAR/PKR also tracks USD/PKR closely.' },
      },
      {
        '@type': 'Question',
        name: 'How to get the best exchange rate when sending money to Pakistan?',
        acceptedAnswer: { '@type': 'Answer', text: 'For the best PKR when sending money to Pakistan: (1) Use Wise or Remitly — they offer rates closest to the interbank rate with low flat fees; (2) Avoid Western Union and MoneyGram for large amounts — their exchange rate spread is higher; (3) For very large transfers (over $5,000), compare bank wire rates directly; (4) Send early in the week — Friday/weekend transfers can sit unprocessed longer. See our remittance comparison guide for current rates.' },
      },
    ],
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-500 mb-6">
      <a href="/" class="hover:text-green-700">Home</a>
      <span class="mx-1">/</span>
      <a href="/tools" class="hover:text-green-700">Tools</a>
      <span class="mx-1">/</span>
      <span>Currency Converter</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">{title}</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6 text-sm">
      Live currency conversion using State Bank of Pakistan (SBP) interbank exchange rates.
      Includes 30-day PKR trend chart for each currency pair.
    </p>

    <CurrencyConverter client:load />

    <div class="mt-6 p-3 bg-gray-50 border border-gray-200 rounded text-xs text-gray-600">
      Rates shown are SBP interbank rates. Actual remittance and exchange counter rates vary by
      provider and may differ significantly. RON (Romanian Leu) is included for the Pakistani
      diaspora in Romania.
    </div>

    <!-- FAQ / SEO content -->
    <div class="mt-12 prose prose-sm max-w-none text-gray-700 dark:text-gray-300">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mt-8 mb-3">Frequently Asked Questions</h2>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">What is the USD to PKR rate today?</h3>
      <p>Shown live above from SBP interbank data. Open market rates at exchange shops typically differ by PKR 1–3. Remittance services like Wise and Remitly offer near-interbank rates.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">What is the AED to PKR rate?</h3>
      <p>Shown live above. AED is pegged to USD at 3.6725, so AED/PKR closely tracks USD/PKR. Critical for the Pakistani community in the UAE — one of Pakistan's largest remittance corridors.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">What is the SAR to PKR rate?</h3>
      <p>Shown live above. SAR is pegged to USD at 3.75. Saudi Arabia is Pakistan's single largest remittance source. SAR/PKR = USD/PKR ÷ 3.75.</p>

      <h3 class="font-semibold text-gray-800 dark:text-white mt-5 mb-2">How to get the best rate sending money to Pakistan?</h3>
      <p>Use Wise or Remitly for the closest-to-interbank rates. Avoid airport counters and Western Union for large amounts. Send weekdays — Friday evening transfers can sit over the weekend. See our <a href="/us/send-money-to-pakistan-from-usa/" class="text-green-600 underline">remittance comparison guide</a> for current rates by service.</p>
    </div>
  </div>
</MainLayout>
