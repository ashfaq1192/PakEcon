---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';

const title = 'AED to PKR Today — UAE Dirham to Pakistani Rupee Rate 2026';
const description = 'Live AED to PKR exchange rate today. UAE Dirham to Pakistani Rupee from SBP interbank. Updated daily. For Pakistani workers and expats in the UAE sending money home.';
const pageUrl = 'https://hisaabkar.pk/rates/aed-pkr-today';

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  dateModified: new Date().toISOString().split('T')[0],
  author: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  publisher: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  inLanguage: 'en-US',
  isAccessibleForFree: true,
  keywords: 'AED to PKR today, UAE dirham to Pakistani rupee, dirham rate Pakistan, 1 AED to PKR, dollar rate UAE Pakistan',
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the AED to PKR rate today?',
      acceptedAnswer: { '@type': 'Answer', text: 'The live AED (UAE Dirham) to PKR exchange rate is shown in the widget above. The AED is pegged to the US dollar at 3.6725 AED per USD. So AED/PKR = USD/PKR ÷ 3.6725. When USD/PKR is 278, AED/PKR is approximately 75.7. The rate updates daily based on SBP interbank data.' },
    },
    {
      '@type': 'Question',
      name: 'Why is the AED pegged to USD?',
      acceptedAnswer: { '@type': 'Answer', text: 'The UAE Dirham has been pegged to the US dollar at 3.6725 since 1997, backed by the UAE\'s vast oil revenues and sovereign wealth fund. This fixed peg provides exchange rate stability. It means AED/PKR fluctuates only when USD/PKR changes — not because of anything happening in the UAE economy.' },
    },
    {
      '@type': 'Question',
      name: 'What is the best app to send money from UAE to Pakistan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Best options for UAE to Pakistan transfers in 2026: (1) Wise — best exchange rate, fees around 0.5-1%; (2) Al Ansari Exchange — widespread in UAE, competitive rates; (3) LuLu Exchange — popular for Pakistan corridor; (4) Emirates NBD direct transfer; (5) ACE Money Transfer — good for Easypaisa/JazzCash delivery. For amounts above AED 10,000, bank wire is often cheaper than exchange houses.' },
    },
    {
      '@type': 'Question',
      name: 'How many PKR is AED 1000?',
      acceptedAnswer: { '@type': 'Answer', text: 'AED 1000 at a rate of 75.7 PKR/AED = approximately PKR 75,700. Use the live rate widget and conversion table above for the exact current amount.' },
    },
  ],
});
---

<MainLayout {title} {description} type="Article">
  <script type="application/ld+json" set:html={schema} />
  <script type="application/ld+json" set:html={faqSchema} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hisaabkar.pk' },
      { '@type': 'ListItem', position: 2, name: 'Rates', item: 'https://hisaabkar.pk/rates' },
      { '@type': 'ListItem', position: 3, name: 'AED to PKR Today', item: pageUrl },
    ],
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">

    <nav class="text-xs text-gray-500 mb-6">
      <a href="/" class="hover:text-green-700">Home</a>
      <span class="mx-1">/</span>
      <a href="/rates" class="hover:text-green-700">Rates</a>
      <span class="mx-1">/</span>
      <span>AED to PKR Today</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">{title}</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8 text-sm">
      SBP interbank rate · Updated daily · UAE Dirham pegged to USD at 3.6725
    </p>

    <!-- Live rate widget -->
    <div class="border border-amber-200 dark:border-amber-800/40 rounded-2xl p-6 bg-gradient-to-br from-amber-50 to-white dark:from-amber-900/10 dark:to-gray-900 mb-10">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">1 UAE Dirham (AED) =</p>
          <p id="aed-rate" class="text-5xl font-bold text-gray-900 dark:text-white">
            <span class="text-2xl text-gray-400 animate-pulse">Loading…</span>
          </p>
          <p class="text-lg text-gray-500 dark:text-gray-400 mt-2">Pakistani Rupee (PKR)</p>
        </div>
        <div class="text-4xl">🇦🇪→🇵🇰</div>
      </div>
      <div class="mt-4 pt-4 border-t border-amber-100 dark:border-amber-800/30 flex justify-between text-xs text-gray-400">
        <span id="aed-date">—</span>
        <span>Source: State Bank of Pakistan</span>
      </div>
    </div>

    <script>
      (async () => {
        try {
          const res = await fetch('/api/exchange-rates');
          const data = await res.json() as any;
          const usdPkr: number = data.rates?.USD || data.USD || 278;
          const aedPkr = usdPkr / 3.6725;
          const el = document.getElementById('aed-rate');
          if (el) el.textContent = `PKR ${aedPkr.toFixed(2)}`;
          const dateEl = document.getElementById('aed-date');
          if (dateEl) dateEl.textContent = 'As of ' + new Date().toLocaleDateString('en-PK', { day: 'numeric', month: 'short', year: 'numeric' });
        } catch { /* non-blocking */ }
      })();
    </script>

    <!-- Quick conversion table -->
    <div class="mb-10 overflow-x-auto">
      <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">AED Amount</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700 dark:text-gray-300">PKR Equivalent (approx.)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          {[100, 500, 1000, 5000, 10000, 50000].map(aed => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
              <td class="px-4 py-3 text-gray-800 dark:text-gray-200">AED {aed.toLocaleString()}</td>
              <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400 font-mono" id={`aed-${aed}`}>—</td>
            </tr>
          ))}
        </tbody>
      </table>
      <script>
        (async () => {
          try {
            const res = await fetch('/api/exchange-rates');
            const data = await res.json() as any;
            const usdPkr: number = data.rates?.USD || data.USD || 278;
            const aedPkr = usdPkr / 3.6725;
            [100, 500, 1000, 5000, 10000, 50000].forEach(aed => {
              const el = document.getElementById(`aed-${aed}`);
              if (el) el.textContent = `PKR ${(aed * aedPkr).toLocaleString('en-PK', { maximumFractionDigits: 0 })}`;
            });
          } catch { /* non-blocking */ }
        })();
      </script>
    </div>

    <div class="prose prose-lg prose-green max-w-none dark:prose-invert">
      <h2>AED to PKR — UAE's Pakistani Community</h2>
      <p>The UAE is home to over <strong>1.5 million Pakistanis</strong>, making it one of the largest Pakistani communities abroad after Saudi Arabia. Dubai and Abu Dhabi host the majority, with large concentrations in Sharjah, Ajman, and Fujairah. Pakistan receives over $6 billion in remittances from the UAE annually.</p>

      <h2>How AED/PKR is Calculated</h2>
      <p>The UAE Dirham has been <strong>pegged to the US dollar at 3.6725 since 1997</strong>. Therefore: <strong>AED/PKR = USD/PKR ÷ 3.6725</strong>. If USD/PKR = 278, then 1 AED ≈ PKR 75.7.</p>

      <h2>Frequently Asked Questions</h2>
      <h3>What is the AED to PKR rate today?</h3>
      <p>Shown live above. AED/PKR = USD/PKR ÷ 3.6725 (fixed peg). Rate changes only when USD/PKR changes.</p>
      <h3>Best app to send AED to Pakistan?</h3>
      <p>Wise (best rate), Al Ansari Exchange, LuLu Exchange, ACE Money Transfer. For amounts over AED 10,000 — bank wire to HBL/MCB/UBL Pakistan.</p>
    </div>

    <div class="mt-10 p-5 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700">
      <h2 class="text-base font-bold text-gray-800 dark:text-white mb-3">Related Rates & Tools</h2>
      <div class="grid grid-cols-2 gap-3 text-sm">
        <a href="/rates/sar-pkr-today/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">🇸🇦 SAR to PKR Today</a>
        <a href="/rates/usd-pkr-today/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">💵 USD to PKR Today</a>
        <a href="/rates/gbp-pkr-today/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">🇬🇧 GBP to PKR Today</a>
        <a href="/tools/remittance-calculator/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">💸 Remittance Calculator</a>
      </div>
    </div>
  </div>
</MainLayout>
