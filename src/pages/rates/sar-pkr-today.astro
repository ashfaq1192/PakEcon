---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';

const title = 'SAR to PKR Today — Saudi Riyal to Pakistani Rupee Rate 2026';
const description = 'Live SAR to PKR exchange rate today. Saudi Riyal to Pakistani Rupee from SBP interbank. Updated daily. For overseas Pakistanis in Saudi Arabia sending money home.';
const pageUrl = 'https://hisaabkar.pk/rates/sar-pkr-today';

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  dateModified: new Date().toISOString().split('T')[0],
  author: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  publisher: { '@type': 'Organization', name: 'HisaabKar.pk', url: 'https://hisaabkar.pk' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  about: { '@type': 'Thing', name: 'SAR PKR Exchange Rate' },
  inLanguage: 'en-US',
  isAccessibleForFree: true,
  keywords: 'SAR to PKR today, Saudi riyal to Pakistani rupee, riyal rate in Pakistan, 1 SAR to PKR, Pakistan riyal rate',
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the SAR to PKR rate today?',
      acceptedAnswer: { '@type': 'Answer', text: 'The live Saudi Riyal (SAR) to Pakistani Rupee (PKR) exchange rate is shown in the widget above, sourced from the State Bank of Pakistan (SBP) interbank data. The SAR is pegged to the US dollar at 3.75 SAR per USD, so SAR/PKR = USD/PKR ÷ 3.75. When USD/PKR is 278, SAR/PKR = approximately 74.13.' },
    },
    {
      '@type': 'Question',
      name: 'Why does the Saudi Riyal to PKR rate change?',
      acceptedAnswer: { '@type': 'Answer', text: 'The SAR is pegged to the US dollar at a fixed rate of 3.75 SAR = 1 USD. Therefore, SAR/PKR changes whenever USD/PKR changes. If the Pakistani Rupee depreciates against the dollar, you get more PKR per SAR. The exchange rate fluctuates based on Pakistan\'s foreign reserves, IMF program conditions, and broader macroeconomic factors.' },
    },
    {
      '@type': 'Question',
      name: 'What is the best way to send money from Saudi Arabia to Pakistan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Options for sending SAR to Pakistan: (1) Wise (formerly TransferWise) — best exchange rate, lowest fees; (2) Al Rajhi Bank direct transfer — fast for bank-to-bank within KSA; (3) STC Pay — popular digital wallet in Saudi Arabia; (4) Western Union/MoneyGram — cash pickup option; (5) ACE Money Transfer — competitive for Pakistan corridor. Compare rates on the day of transfer as spreads vary. Also check if your Pakistani family has a Roshan Digital Account for faster settlement.' },
    },
    {
      '@type': 'Question',
      name: 'How much SAR equals 100,000 PKR?',
      acceptedAnswer: { '@type': 'Answer', text: 'To convert PKR 100,000 to SAR: divide by the current SAR/PKR rate. If 1 SAR = PKR 74, then PKR 100,000 = approximately SAR 1,351. Use the remittance calculator above to calculate the exact amount based on today\'s live rate.' },
    },
  ],
});
---

<MainLayout {title} {description}>
  <script type="application/ld+json" set:html={schema} />
  <script type="application/ld+json" set:html={faqSchema} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hisaabkar.pk' },
      { '@type': 'ListItem', position: 2, name: 'Rates', item: 'https://hisaabkar.pk/rates' },
      { '@type': 'ListItem', position: 3, name: 'SAR to PKR Today', item: pageUrl },
    ],
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">

    <nav class="text-xs text-gray-500 mb-6">
      <a href="/" class="hover:text-green-700">Home</a>
      <span class="mx-1">/</span>
      <a href="/rates" class="hover:text-green-700">Rates</a>
      <span class="mx-1">/</span>
      <span>SAR to PKR Today</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">{title}</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8 text-sm">
      SBP interbank rate · Updated daily · Saudi Riyal is pegged to USD at 3.75
    </p>

    <!-- Live rate widget -->
    <div id="rate-widget" class="border border-green-200 dark:border-green-800/40 rounded-2xl p-6 bg-gradient-to-br from-green-50 to-white dark:from-green-900/20 dark:to-gray-900 mb-10">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">1 Saudi Riyal (SAR) =</p>
          <p id="rate-value" class="text-5xl font-bold text-gray-900 dark:text-white">
            <span class="text-2xl text-gray-400 animate-pulse">Loading…</span>
          </p>
          <p class="text-lg text-gray-500 dark:text-gray-400 mt-2">Pakistani Rupee (PKR)</p>
        </div>
        <div class="text-4xl">🇸🇦→🇵🇰</div>
      </div>
      <div class="mt-4 pt-4 border-t border-green-100 dark:border-green-800/30 flex items-center justify-between text-xs text-gray-400">
        <span id="rate-date">—</span>
        <span>Source: State Bank of Pakistan</span>
      </div>
    </div>

    <script>
      async function loadRate() {
        try {
          const res = await fetch('/api/exchange-rates');
          if (!res.ok) return;
          const data = await res.json() as any;
          const rates = data.rates || data;
          const usdPkr: number = rates.USD || rates.usd || 278;
          // SAR is pegged to USD at 3.75
          const sarPkr = usdPkr / 3.75;
          const el = document.getElementById('rate-value');
          if (el) el.textContent = `PKR ${sarPkr.toFixed(2)}`;
          const dateEl = document.getElementById('rate-date');
          if (dateEl) dateEl.textContent = 'As of ' + new Date().toLocaleDateString('en-PK', { day: 'numeric', month: 'short', year: 'numeric' });
        } catch { /* non-blocking */ }
      }
      loadRate();
    </script>

    <!-- Quick conversion table -->
    <div class="mb-10 overflow-x-auto">
      <table class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">SAR Amount</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-700 dark:text-gray-300">PKR Equivalent (approx.)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          {[100, 500, 1000, 5000, 10000, 50000].map(sar => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
              <td class="px-4 py-3 text-gray-800 dark:text-gray-200">SAR {sar.toLocaleString()}</td>
              <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400 font-mono" id={`sar-${sar}`}>—</td>
            </tr>
          ))}
        </tbody>
      </table>
      <script>
        (async () => {
          try {
            const res = await fetch('/api/exchange-rates');
            const data = await res.json() as any;
            const usdPkr: number = data.rates?.USD || data.USD || 278;
            const sarPkr = usdPkr / 3.75;
            [100, 500, 1000, 5000, 10000, 50000].forEach(sar => {
              const el = document.getElementById(`sar-${sar}`);
              if (el) el.textContent = `PKR ${(sar * sarPkr).toLocaleString('en-PK', { maximumFractionDigits: 0 })}`;
            });
          } catch { /* non-blocking */ }
        })();
      </script>
    </div>

    <!-- Article content -->
    <div class="prose prose-lg prose-green max-w-none dark:prose-invert">

      <h2>SAR to PKR Exchange Rate — Pakistan's Biggest Remittance Corridor</h2>
      <p>
        Saudi Arabia is Pakistan's <strong>single largest source of remittances</strong>. Pakistan received over $8 billion from Saudi Arabia alone in FY 2024-25, making the SAR/PKR rate one of the most-watched currency pairs for millions of Pakistani families. Over 2 million Pakistani workers live and work in Saudi Arabia across construction, healthcare, retail, and domestic sectors.
      </p>

      <h2>How SAR/PKR Rate is Determined</h2>
      <p>
        The Saudi Riyal is <strong>pegged to the US dollar at a fixed rate of 3.75 SAR = 1 USD</strong>. This peg has been in place since 1986 and is backed by Saudi Arabia's massive foreign exchange reserves (approximately $450 billion). Because of this fixed peg, the SAR/PKR rate moves exactly in proportion to the USD/PKR rate:
      </p>
      <p><strong>SAR/PKR = USD/PKR ÷ 3.75</strong></p>
      <p>
        When Pakistan's rupee weakens against the dollar, workers in Saudi Arabia get more rupees per riyal — their families benefit from the depreciation.
      </p>

      <h2>Best Way to Send SAR to Pakistan</h2>
      <p>
        For Pakistani workers in Saudi Arabia sending money home, these are the most popular options in 2026:
      </p>
      <ul>
        <li><strong>Wise:</strong> Closest to the interbank rate, low flat fee, delivers to Pakistani bank accounts in 1-2 days</li>
        <li><strong>Al Rajhi Bank:</strong> Widely used in KSA; competitive rates for direct bank-to-bank transfers</li>
        <li><strong>STC Pay:</strong> Saudi Arabia's popular digital wallet; integrates with Pakistani mobile wallets</li>
        <li><strong>ACE Money Transfer:</strong> Good rates for cash pickup at Easypaisa/JazzCash agents</li>
        <li><strong>Roshan Digital Account transfer:</strong> If your family has an RDA, transfers settle within hours</li>
      </ul>

      <h2>Frequently Asked Questions</h2>

      <h3>What is the SAR to PKR rate today?</h3>
      <p>Shown live in the widget above. SAR/PKR = USD/PKR ÷ 3.75 (since SAR is pegged to USD at 3.75).</p>

      <h3>Why does SAR/PKR change?</h3>
      <p>Because the SAR is fixed to USD at 3.75, SAR/PKR changes only when USD/PKR changes — driven by Pakistan's forex reserves, IMF program, trade deficit, and remittance inflows.</p>

      <h3>How much SAR equals PKR 100,000?</h3>
      <p>At SAR/PKR of approximately 74: SAR 100,000 ≈ PKR 7,400,000. To reverse: PKR 100,000 ÷ 74 ≈ SAR 1,351.</p>
    </div>

    <!-- Related tools -->
    <div class="mt-10 p-5 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700">
      <h2 class="text-base font-bold text-gray-800 dark:text-white mb-3">Related Tools & Rates</h2>
      <div class="grid grid-cols-2 gap-3 text-sm">
        <a href="/tools/remittance-calculator/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">💸 Remittance Calculator</a>
        <a href="/rates/usd-pkr-today/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">💵 USD to PKR Today</a>
        <a href="/rates/aed-pkr-today/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">🇦🇪 AED to PKR Today</a>
        <a href="/rates/gbp-pkr-today/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">🇬🇧 GBP to PKR Today</a>
        <a href="/us/send-money-to-pakistan-from-usa/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">🚀 Send Money Guide</a>
        <a href="/tools/currency-converter/" class="flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline">💱 Full Currency Converter</a>
      </div>
    </div>

  </div>
</MainLayout>
