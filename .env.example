# PakEcon.ai Environment Variables Template
# Copy this file to .env and fill in your actual values for local testing
# DO NOT commit .env to git - only .env.example should be committed

# ============================================
# REQUIRED SECRETS (For Local Testing)
# ============================================

# Agent authentication secret (generate your own)
# Generate with: openssl rand -base64 32
# Used to authenticate requests to /api/agents/trigger
AGENT_SECRET=your-generated-secret-here-min-32-characters

# ============================================
# REQUIRED VARIABLES (For Local Testing)
# ============================================

# Your local development URL for testing
# Used for health checks and agent trigger URL
SITE_URL=http://localhost:8787
AGENT_URL=http://localhost:8787/api/agents/trigger

# ============================================
# OPTIONAL SECRETS (Google Indexing API)
# ============================================

# Google Indexing API Private Key
# Get from: https://console.cloud.google.com/apis/credentials
# Create Service Account > Download JSON > Copy private_key field
# Leave empty if you don't want to use Google Indexing
GOOGLE_PRIVATE_KEY=

# Google Service Account Email
# Get from the same JSON file as GOOGLE_PRIVATE_KEY
# Format: your-project@project-id.iam.gserviceaccount.com
# Leave empty if you don't want to use Google Indexing
GOOGLE_SERVICE_ACCOUNT=

# ============================================
# DATABASE VARIABLES (Usually in wrangler.toml)
# ============================================

# D1 Database Binding Name (matches wrangler.toml)
# This is typically "DB" for the binding
DB_BINDING=DB

# D1 Database Name (matches wrangler.toml)
D1_DATABASE_NAME=pakecon_db

# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================

# Application environment (development/staging/production)
NODE_ENV=development

# Astro site URL (for SEO and canonical links)
# Change to your production domain when deploying
SITE_DOMAIN=http://localhost:8787

# ============================================
# CLOUDFLARE CONFIGURATION (for local dev)
# ============================================

# Cloudflare Account ID (optional - for some Wrangler commands)
# Leave empty unless needed
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API Token (optional - for programmatic deployments)
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Leave empty unless deploying via API
CLOUDFLARE_API_TOKEN=
